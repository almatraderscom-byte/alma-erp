<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ (dataExtractionRules): exclude the same live-session data from BOTH
     cloud backup and device-to-device transfer. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="." />
        <exclude domain="database" path="." />
        <exclude domain="file" path="app_webview" />
        <exclude domain="file" path="app_textures" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="." />
        <exclude domain="database" path="." />
        <exclude domain="file" path="app_webview" />
        <exclude domain="file" path="app_textures" />
    </device-transfer>
</data-extraction-rules>
