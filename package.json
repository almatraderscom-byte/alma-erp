{
  "name": "alma-lifestyle-erp",
  "version": "1.0.0",
  "private": true,
  "prisma": {
    "seed": "node prisma/seed.cjs"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "verify": "npm run type-check && npm run build",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "regression:gate": "node scripts/regression-gate.mjs",
    "regression:gate:auth": "REQUIRE_REGRESSION_AUTH=1 node scripts/regression-gate.mjs",
    "regression:setup-secrets": "bash scripts/setup-github-regression-secrets.sh",
    "regression:verify-auth": "node scripts/verify-regression-auth.mjs",
    "db:migrate:status": "prisma migrate status",
    "db:migrate:check": "node scripts/check-pending-migrations.mjs",
    "regression:smoke": "node scripts/regression-smoke.mjs",
    "regression:typecheck": "tsc --noEmit",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "node prisma/seed.cjs",
    "backup:prod": "node scripts/backup-production.mjs",
    "backup:dry-run": "node scripts/backup-production.mjs --dry-run --no-upload",
    "backup:recovery-validate": "node scripts/recovery-validate.mjs",
    "gas:status": "clasp status",
    "gas:push": "clasp push --force",
    "gas:deploy": "bash scripts/gas-deploy.sh",
    "gas:health-check": "bash scripts/health-check.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.104.1",
    "@prisma/client": "5.22.0",
    "@react-pdf/renderer": "^4.5.1",
    "@sentry/nextjs": "^8.55.2",
    "bcryptjs": "^3.0.3",
    "date-fns": "3.6.0",
    "framer-motion": "11.2.9",
    "next": "14.2.3",
    "next-auth": "^4.24.11",
    "qrcode": "^1.5.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hot-toast": "2.4.1",
    "recharts": "2.12.7",
    "resend": "^6.12.3",
    "sharp": "^0.34.5",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "20.13.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.3",
    "postcss": "8.4.38",
    "prisma": "5.22.0",
    "tailwindcss": "3.4.3",
    "typescript": "5.4.5"
  }
}
