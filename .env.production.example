# Alma ERP — production environment template
# Copy to .env.production.local or configure in Vercel Project → Settings → Environment Variables.

# ── Stable Google Apps Script web app (NEVER rotate URL — redeploy same deployment via npm run gas:deploy)
# Must match config/gas-production-deployment.txt → https://script.google.com/macros/s/<ID>/exec
NEXT_PUBLIC_API_URL=https://script.google.com/macros/s/AKfycbwa0DpWEpIKwUZdRkdWFU9Gv_MEtoB1p8mAOQGOOn21u9KZ1sAVZcD6yasI65rSlbSF/exec

# Same ID as in NEXT_PUBLIC_API_URL (optional — parsed automatically if omitted)
GAS_DEPLOYMENT_ID=AKfycbwa0DpWEpIKwUZdRkdWFU9Gv_MEtoB1p8mAOQGOOn21u9KZ1sAVZcD6yasI65rSlbSF

# Server-only — must match Apps Script Script Property API_SECRET (never expose as NEXT_PUBLIC_*)
API_SECRET=

# Public site URL (invoice links, redirects)
NEXT_PUBLIC_APP_URL=https://your-project.vercel.app
NEXTAUTH_URL=https://your-project.vercel.app
NEXTAUTH_SECRET=
DATABASE_URL=
CRON_SECRET=
SESSION_MAX_AGE_SECONDS=2592000
NEXT_PUBLIC_ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=
ONESIGNAL_ANDROID_CHANNEL_ID=
RESEND_API_KEY=
EMAIL_FROM=Alma ERP <onboarding@resend.dev>

# Private Supabase Storage bucket for expense receipt/document uploads.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_EXPENSE_RECEIPTS_BUCKET=expense-receipts

# Optional public Supabase client values. Do not put service-role keys in NEXT_PUBLIC_* vars.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional — paste clasp deploy output "@NN" so /api/health shows Google snapshot id without opening Apps Script.
GAS_CLASP_VERSION=
