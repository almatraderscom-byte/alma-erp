#   <NEXTAUTH_URL>/api/assistant/creative-studio/drive-auth/callback
# Set BOTH on Vercel (app) AND the VPS worker env. Owner connects once via the Studio "Connect Google Drive" button.
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
# Google Search Console (read-only SEO data — Growth Feature 1). OAuth on the owner's own account,
# scope webmasters.readonly. Enable the "Google Search Console API" in the GCP project and add redirect URI:
#   <NEXTAUTH_URL>/api/assistant/growth/gsc-auth/callback
# If GSC_CLIENT_ID/SECRET are blank the app reuses GOOGLE_DRIVE_CLIENT_ID/SECRET above (just add the scope + redirect
# to that OAuth client). Refresh token is stored in the DB when the owner clicks "Connect" — not set here.
GSC_CLIENT_ID=
GSC_CLIENT_SECRET=
GSC_SITE_URL=              # optional, e.g. sc-domain:almatraders.com — auto-detected from the account if blank
# Google Analytics 4 (read-only traffic/conversion/revenue — Growth Feature 5). Reuses the SAME Google OAuth as GSC
# above (the consent now also requests analytics.readonly, so the owner re-clicks "Connect" once on the Growth page).
# GA4_PROPERTY_ID is the numeric Property ID (GA4 Admin → Property Settings → Property ID, e.g. 123456789 — NOT the
# "G-XXXX" measurement id). Powers the get_ga4_report agent tool.
GA4_PROPERTY_ID=
# Meta Ads MCP (Phase MA1 — official mcp.facebook.com/ads, read-only tools). Kill switch: default OFF;
# also owner-toggleable at runtime via kv meta_mcp_enabled. Tokens are stored in the DB when the owner
# clicks "Connect Meta Ads" on /agent/growth — not set here. META_MCP_ENDPOINT override is for tests only.
# META_MCP_CLIENT_ID/SECRET are optional: dynamic client registration is tried first, then the owner's
# ALMA AI AGENT app id as documented fallback.
META_MCP_ENABLED=false
META_MCP_ENDPOINT=https://mcp.facebook.com/ads
META_MCP_CLIENT_ID=
META_MCP_CLIENT_SECRET=
# IndexNow instant re-crawl ping (Growth Feature 4). FREE, no OAuth. Broadcasts changed URLs to Bing/Yandex/Naver/
# Seznam (NOT Google — Google uses the sitemap + Search Console). Generate an 8-128 char hex key (e.g. `openssl rand
# -hex 16`) and ALSO host it as a plain-text file at https://www.almatraders.com/<key>.txt on the STOREFRONT repo
# (its /public folder) — the storefront is a separate deploy, so the key file must be added there. Without the key
# file the ping is accepted (HTTP 202) but engines won't crawl.
INDEXNOW_KEY=
# BD SMS gateway (sms.net.bd) — already used by ERP transactional SMS; ALSO powers the agent's
# draft_marketing_campaign (Growth Feature 6, strictly owner-approval-gated). Set on Vercel.
