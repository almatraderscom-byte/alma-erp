TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_RATE_LIMIT_PER_MINUTE=12
# BD hour (0-23) when prior-day PENDING drafts auto-lock (default 6)
TELEGRAM_DRAFT_LOCK_HOUR_BD=6
# Owner/admin Telegram chat IDs for ops alerts (comma-separated). DB settings take priority; this env is fallback.
# Also accepts legacy alias OWNER_TELEGRAM_CHAT_IDS. Example: 1949042834,987654321
TELEGRAM_OWNER_CHAT_IDS=
OWNER_TELEGRAM_CHAT_IDS=
# HMAC secret for Telegram sendPhoto preview URLs (defaults to TELEGRAM_WEBHOOK_SECRET / CRON_SECRET)
