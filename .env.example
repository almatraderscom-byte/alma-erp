NEXT_PUBLIC_API_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
API_SECRET=your-strong-secret-here

# Shared secret for almatraders.com → ERP order ingest (POST /api/orders/website)
WEBSITE_ORDER_SECRET=generate-a-long-random-secret-min-32-chars

# Hermes agent read-only orders API (GET /api/agent/orders/*)
# Same value as ALMA_ERP_API_KEY on Hermes VPS
ALMA_AGENT_API_KEY=

# Postgres (Supabase)
# Production (Vercel/serverless): use Transaction pooler on port 6543 — required for many short-lived connections.
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10"
# Local Prisma CLI (db push / migrate): use direct connection on port 5432, or add DIRECT_URL in schema.prisma.
# DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"

NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000
CRON_SECRET=generate-with-openssl-rand-base64-32
SESSION_MAX_AGE_SECONDS=2592000
NEXT_PUBLIC_ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=
ONESIGNAL_ANDROID_CHANNEL_ID=alma_alerts
RESEND_API_KEY=
EMAIL_FROM=Alma ERP <onboarding@resend.dev>

# Attendance GPS — ALMA_LIFESTYLE office location (set on Vercel Production)
OFFICE_ALMA_LIFESTYLE_LAT=
OFFICE_ALMA_LIFESTYLE_LNG=
OFFICE_ALMA_LIFESTYLE_RADIUS_M=300

# Supabase Storage for private expense receipt/document uploads.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_EXPENSE_RECEIPTS_BUCKET=expense-receipts

# Optional public Supabase client values. Do not put service-role keys in NEXT_PUBLIC_* vars.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Alma Lifestyle storefront (almatraders.com) — website catalog Supabase project.
# Use HTTPS project URL (https://PROJECT_REF.supabase.co), NOT the Postgres connection string.
WEBSITE_SUPABASE_URL=https://YOUR_WEBSITE_PROJECT_REF.supabase.co
WEBSITE_SUPABASE_SERVICE_ROLE_KEY=

# Oxylabs AI Studio — used by web_research agent tool (SEO/competitor/market research).
# Hostinger VPS: copy API key from Docker Manager → Oxylabs AI credits → Key button.
# 1000-credit prepaid pack; no separate Oxylabs username/password needed.
OXYLABS_API_KEY=

# Optional fallback — direct Oxylabs Web Scraper account (not Hostinger bundle):
# OXYLABS_USERNAME=
# OXYLABS_PASSWORD=

# Alma Trading Telegram quick-entry bot (set in Vercel — never commit real tokens)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_RATE_LIMIT_PER_MINUTE=12
# BD hour (0-23) when prior-day PENDING drafts auto-lock (default 6)
TELEGRAM_DRAFT_LOCK_HOUR_BD=6
# Owner/admin Telegram chat IDs for ops alerts (comma-separated). DB settings take priority; this env is fallback.
# Also accepts legacy alias OWNER_TELEGRAM_CHAT_IDS. Example: 1949042834,987654321
TELEGRAM_OWNER_CHAT_IDS=
OWNER_TELEGRAM_CHAT_IDS=
# HMAC secret for Telegram sendPhoto preview URLs (defaults to TELEGRAM_WEBHOOK_SECRET / CRON_SECRET)
TELEGRAM_PREVIEW_SECRET=

# Sentry (production monitoring — set in Vercel + VPS worker, optional locally)
# Agent routes/worker tag events with module:agent to separate ERP noise.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_PROFILES_SAMPLE_RATE=0
# Session Replay (only on error — never random sessions).
# Production default: 0.20 (20% of error-bearing sessions). 0 disables replay entirely.
SENTRY_REPLAY_SESSION_SAMPLE_RATE=0
SENTRY_REPLAY_ERROR_SAMPLE_RATE=0.2
# SENTRY_ENABLED=false
# SENTRY_DEBUG=true

# --- AGENT MODULE ---
# Kill switch: set to "true" in Vercel PREVIEW only to test. Keep "false" in production until owner approves.
AGENT_ENABLED=false
AGENT_COMPACT_THRESHOLD_USD=25  # Safety valve only: fold a chat into a summary when it gets this expensive (USD). No daily fold — full history is kept so the agent keeps remembering.
# Plan-Driver kill switch (autonomous pursue-until-completion). Default OFF.
# When != "true" the driver is fully inert (no DB scan, no cost). Phase A only runs
# in shadow/dry-run mode even when ON. Cost caps + gate model are owner-tunable in agent_kv_settings.
AGENT_AUTODRIVE_ENABLED=false
# Claude-Code-style deferred tool loading. Default: ON in Vercel preview, OFF in production.
# Leave UNSET to get that default. Set "true" to force on (e.g. production after approval); "false" to force off anywhere (instant kill switch).
# AGENT_TOOL_SEARCH=
# Slim Head Router (Project A): head carries a lean tool set + delegates heavy domains to cheap workers. Default ON (owner runs it live, protected by the approval gate). Set "false" to disable. Critical execution stays on Claude.
# ENABLE_SLIM_ROUTER=
# Delegation approval: the head does NOT run workers itself — for marketing/specialist work it asks the owner first ("transfer to <worker>?") and the worker (Qwen/DeepSeek) starts only on approval. Also strips marketing tools from the head so it must transfer. Default ON. Set "false" to disable. Needs OPENROUTER_API_KEY for the workers to run.
# DELEGATION_APPROVAL=
# Self-diagnostic: VPS worker reads local repo for grep/read during diagnosis
AGENT_REPO_PATH=/opt/alma-erp
# Vercel → VPS worker proxy for code-search (grep/read source on VPS)
AGENT_WORKER_DIAGNOSTIC_URL=http://31.97.237.40:3098
# Content engine (Phase 3): autonomous prep — still needs both owner approvals to publish
CONTENT_ENGINE_ENABLED=false
CONTENT_ENGINE_PHASE=1
CONTENT_ENGINE_VARIANTS=single,father_son
CONTENT_ENGINE_PER_DAY=1
CONTENT_ENGINE_MIN_DAYS_BETWEEN=2
CONTENT_ENGINE_MAX_PENDING=2
CONTENT_ENGINE_QUALITY_DRAFT_FIRST=true
ANTHROPIC_API_KEY=
ANTHROPIC_ADMIN_API_KEY=   # Optional: org cost_report for balance dashboard (sk-ant-admin...)
OPENROUTER_API_KEY=        # Cheap sub-agent tiers (GLM / Gemini Flash Lite via openrouter.ai)
OPENROUTER_MANAGEMENT_KEY= # OpenRouter MANAGEMENT key — read-only, for the cost dashboard's Activity API (per-day spend). NEVER used for inference (would break model calls). Keep separate from OPENROUTER_API_KEY.
# Google Gemini (image gen + Veo 3.1 reels)
GEMINI_API_KEY=

# FASHN AI — Pro fashion try-on (Creative Studio). Get key: https://fashn.ai/products/api
FASHN_API_KEY=
OPENAI_API_KEY=            # Whisper transcription + embeddings (Phase 3/8)
# Optional: OpenAI org usage reconciliation (Phase 8 nightly job)
OPENAI_ORG_ID=
OPENAI_ADMIN_API_KEY=      # Falls back to OPENAI_API_KEY if unset
GOOGLE_TTS_CREDENTIALS=    # path or JSON for bn-IN-Chirp3-HD-Charon (Salah reminders).
# Creative Studio → Google Drive auto-archive (OAuth on the owner's own Drive, scope drive.file).
# Create an OAuth 2.0 Client ID (Web application) and add the redirect URI:
#   <NEXTAUTH_URL>/api/assistant/creative-studio/drive-auth/callback
# Set BOTH on Vercel (app) AND the VPS worker env. Owner connects once via the Studio "Connect Google Drive" button.
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
ELEVENLABS_API_KEY=        # ElevenLabs Starter plan API key
ELEVENLABS_MODEL_ID=eleven_v3
ELEVENLABS_VOICE_STAFF=IKne3meq5aSn9XLyUdCD    # Charlie — staff announcements
ELEVENLABS_VOICE_MALE=IKne3meq5aSn9XLyUdCD     # Charlie — owner male / calls
ELEVENLABS_VOICE_FEMALE=SAz9YHcvj6GT2YYXdXww   # River — owner female (optional)
# ELEVENLABS_STABILITY=0.5
# ELEVENLABS_SIMILARITY_BOOST=0.75
# ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
# --- ElevenLabs Conversational AI outbound phone calls (two-way Bangla; family/friends/work) ---
# Kill switch — OFF by default. Set to true to let the agent place real phone calls.
VOICE_CALL_ENABLED=false
# Created in ElevenLabs dashboard → Conversational AI → Agents (Bangla language + your voice, enable overrides).
ELEVENLABS_AGENT_ID=
# ElevenLabs dashboard → Phone Numbers → import your Twilio number → copy the phone_number_id.
ELEVENLABS_AGENT_PHONE_NUMBER_ID=
# ElevenLabs dashboard → Conversational AI → Settings → Post-call webhook → copy the signing secret (wsec_...).
ELEVENLABS_WEBHOOK_SECRET=
# Safety caps (optional; sensible defaults applied in code).
# VOICE_CALL_DAILY_CAP=10            # max agent-placed calls per Dhaka day
# VOICE_CALL_MAX_MINUTES=10          # hint passed to the agent per call
# Phase 5 — NEW assistant bot (different token from the Hermes ERP bot above)
# Create via BotFather: /newbot → pick a name → copy the token here
ASSISTANT_BOT_TOKEN=       # e.g. 7654321098:AABBCCDDEEFFaabbccddeeff1122334455
TELEGRAM_OWNER_CHAT_ID=    # Your personal Telegram chat ID — MUST be set on VPS worker for shadow draft notifications (send /start to @userinfobot to find it)
TELEGRAM_STAFF_GROUP_CHAT_ID= # Office staff Telegram group chat id (negative number). Fallback for the idle-nudge target; preferred: set KV "idle_nudge_chat_id" (no redeploy). When idle alert is approved, the name-free reminder goes here.
# Imou camera — staff idle-detection pilot. Create a developer app at
# open.imoulife.com → My Application → Application Information for AppId/AppSecret,
# then bind the office camera. IMOU_DEVICE_ID = the bound camera's device id.
IMOU_APP_ID=               # e.g. lc116b5b6bcfe244e7
IMOU_APP_SECRET=           # keep secret — never commit the real value
IMOU_DEVICE_ID=            # bound camera device id (Work Room camera for the pilot)
# IMOU_API_BASE=https://openapi-sg.easy4ip.com/openapi   # Asia DC default; override per account region

# ntfy push notifications — self-hosted on VPS recommended (https://ntfy.sh for quick start)
NTFY_SERVER=https://ntfy.sh          # or https://ntfy.yourdomain.com
NTFY_TOPIC_GENERAL=alma-agent        # Tier 1 general alerts topic
NTFY_TOPIC_CRITICAL=alma-agent-crit  # Tier 2 critical alerts topic (configure priority in ntfy app)
TWILIO_ACCOUNT_SID=        # Phase 5+
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=        # E.164 format, e.g. +14155551234 — all non-salah outbound calls
TWILIO_TO_NUMBER=          # Owner's phone number in E.164 format, e.g. +8801XXXXXXXXX
# Dedicated OUTBOUND number for salah-reminder calls ONLY. Buy a second Twilio number on the
# same account. If unset, salah calls fall back to TWILIO_FROM_NUMBER.
# This number must NEVER be used for any non-salah call.
# Owner: leave inbound webhook blank/reject on this number (outbound-salah-only).
TWILIO_SALAH_FROM_NUMBER=
# Twilio WhatsApp — the business WhatsApp sender (reuses TWILIO_ACCOUNT_SID/AUTH_TOKEN above).
# Value = your Twilio WhatsApp number, e.g. whatsapp:+8801XXXXXXXXX (the "whatsapp:" prefix is optional).
TWILIO_WHATSAPP_FROM=
# Kill switch: WhatsApp send stays OFF until this is exactly "true" (even with creds set).
WHATSAPP_SEND_ENABLED=
# PUBLIC business WhatsApp number (digits only, e.g. 15559735455) for the staff
# home-page "WhatsApp-এ যুক্ত হন" opt-in button (wa.me deep link → staff sends a
# pre-written message → opens the 24h window). Unset = the button is hidden.
NEXT_PUBLIC_WA_BUSINESS_NUMBER=
# Kill switch: one-way WhatsApp VOICE calls stay OFF until this is exactly "true".
# Beyond this, WhatsApp requires Business Calling enabled on the sender AND the
# recipient to have granted call permission, or Twilio rejects the call.
WHATSAPP_CALL_ENABLED=
# Owner's WhatsApp number (e.g. +8801XXXXXXXXX). When set (+ WHATSAPP_SEND_ENABLED=true),
# the agent MIRRORS owner notifications/reminders to WhatsApp alongside Telegram.
# Free-form only delivers inside WhatsApp's 24h window (owner must have messaged the
# business number within 24h).
OWNER_WHATSAPP_NUMBER=
# Kill switch (VPS WORKER) for staff WhatsApp notifications — task dispatch / announcements
# also go to a staffer's WhatsApp (best-effort, only inside their 24h opt-in window).
# OFF until exactly "true". Needs TWILIO_WHATSAPP_FROM on the worker too. Default OFF.
STAFF_WHATSAPP_ENABLED=
REDIS_URL=                 # VPS worker queue (Phase 4+)
LONG_TASK_REDIS_URL=       # A2 background turns: CLOUD Redis (e.g. Upstash) reachable from BOTH Vercel AND the VPS worker. Required for >280s turns to hand off. Falls back to REDIS_URL. Set the SAME value on Vercel + worker.
AGENT_INTERNAL_TOKEN=      # Long random secret — worker→app callback auth (Phase 4+)
# Remote MCP "connector" (/api/assistant/mcp) — least-privilege bearer for an external Claude
# co-worker. SEPARATE secret from everything else (read-only, default-deny tool scope). Rotate
# independently. Leave blank to disable the connector entirely (route returns 401).
CONNECTOR_TOKEN=           # Long random secret — Bearer auth for the read-only Claude connector
FB_PAGE_TOKEN_LIFESTYLE=   # Meta Graph API page token for Alma Lifestyle — MUST be set on BOTH Vercel AND VPS worker (webhook runs on Vercel, sends run on worker)
FB_PAGE_TOKEN_ONLINESHOP=  # Meta Graph API page token for Alma Online Shop — MUST be set on BOTH Vercel AND VPS worker
# CS-1 — Messenger webhook (customer sales agent)
META_APP_ID=                # Meta App ID with Business Manager linked (e.g. 1990978398451639)
META_APP_SECRET=            # App Secret for META_APP_ID (X-Hub-Signature-256 validation)
META_WRONG_APP_IDS=         # Comma-separated legacy app IDs to unsubscribe from pages (e.g. 1561833048688297)
META_WEBHOOK_VERIFY_TOKEN=  # Custom verify token for webhook subscription
CS_STAFF_EYAFI_CHAT_ID=     # Optional: Eyafi Telegram chat for shadow drafts (falls back to DB agent_staff)
CS_AUTO_CONFIDENCE_THRESHOLD=0.72  # Live auto-reply minimum confidence (0-1). Below → escalate to human.
# Phase 4 — WhatsApp Cloud API (Coexistence, shadow mode first)
WA_PHONE_ID=               # WhatsApp Business phone_number_id from Meta
WA_TOKEN=                  # Permanent access token with whatsapp_business_messaging — Vercel + VPS
WA_VERIFY_TOKEN=           # Webhook verify token (falls back to META_WEBHOOK_VERIFY_TOKEN)
WA_WABA_ID=                # WhatsApp Business Account ID (template listing)
# Phase 6 — Ads monitoring (read-only, ads_read permission required)
META_ADS_TOKEN=            # Meta Marketing API access token with ads_read permission
META_AD_ACCOUNT_ID=        # Meta Ads account ID, e.g. act_1234567890
# Phase 6 — Schedulers kill switch (set to "true" on VPS worker to enable all scheduled jobs)
SCHEDULERS_ENABLED=false
# Phase 6 — Hermes SQLite DB path (migration script runs ON the VPS, not on Vercel)
# HERMES_DB_PATH=/opt/hermes/code/apps/api/.hermes/hermes.db

# Auto-Fix — Cursor SDK cloud agent for automated bug fixes
CURSOR_API_KEY=           # Cursor API key from cursor.com/dashboard > Integrations
AUTOFIX_GITHUB_REPO=almatraderscom-byte/alma-erp
AUTOFIX_GITHUB_BRANCH=main
