# Sentry (production monitoring — set in Vercel + VPS worker, optional locally)
# Agent routes/worker tag events with module:agent to separate ERP noise.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_PROFILES_SAMPLE_RATE=0
# Session Replay (only on error — never random sessions).
# Production default: 0.20 (20% of error-bearing sessions). 0 disables replay entirely.
SENTRY_REPLAY_SESSION_SAMPLE_RATE=0
SENTRY_REPLAY_ERROR_SAMPLE_RATE=0.2
# SENTRY_ENABLED=false
# SENTRY_DEBUG=true

# --- AGENT MODULE ---
# Kill switch: set to "true" in Vercel PREVIEW only to test. Keep "false" in production until owner approves.
AGENT_ENABLED=false
AGENT_COMPACT_THRESHOLD_USD=25  # Safety valve only: fold a chat into a summary when it gets this expensive (USD). No daily fold — full history is kept so the agent keeps remembering.
# Plan-Driver kill switch (autonomous pursue-until-completion). Default OFF.
# When != "true" the driver is fully inert (no DB scan, no cost). Phase A only runs
# in shadow/dry-run mode even when ON. Cost caps + gate model are owner-tunable in agent_kv_settings.
AGENT_AUTODRIVE_ENABLED=false
# Claude-Code-style deferred tool loading. Default: ON in Vercel preview, OFF in production.
# Leave UNSET to get that default. Set "true" to force on (e.g. production after approval); "false" to force off anywhere (instant kill switch).
# AGENT_TOOL_SEARCH=
# Slim Head Router (Project A): head carries a lean tool set + delegates heavy domains to cheap workers. Default ON (owner runs it live, protected by the approval gate). Set "false" to disable. Critical execution stays on Claude.
# ENABLE_SLIM_ROUTER=
# Delegation approval: the head does NOT run workers itself — for marketing/specialist work it asks the owner first ("transfer to <worker>?") and the worker (Qwen/DeepSeek) starts only on approval. Also strips marketing tools from the head so it must transfer. Default ON. Set "false" to disable. Needs OPENROUTER_API_KEY for the workers to run.
# DELEGATION_APPROVAL=
# Self-diagnostic: VPS worker reads local repo for grep/read during diagnosis
AGENT_REPO_PATH=/opt/alma-erp
# Vercel → VPS worker proxy for code-search (grep/read source on VPS)
AGENT_WORKER_DIAGNOSTIC_URL=http://31.97.237.40:3098
# Content engine (Phase 3): autonomous prep — still needs both owner approvals to publish
CONTENT_ENGINE_ENABLED=false
CONTENT_ENGINE_PHASE=1
CONTENT_ENGINE_VARIANTS=single,father_son
CONTENT_ENGINE_PER_DAY=1
CONTENT_ENGINE_MIN_DAYS_BETWEEN=2
CONTENT_ENGINE_MAX_PENDING=2
CONTENT_ENGINE_QUALITY_DRAFT_FIRST=true
ANTHROPIC_API_KEY=
ANTHROPIC_ADMIN_API_KEY=   # Optional: org cost_report for balance dashboard (sk-ant-admin...)
OPENROUTER_API_KEY=        # Cheap sub-agent tiers (GLM / Gemini Flash Lite via openrouter.ai)
OPENROUTER_MANAGEMENT_KEY= # OpenRouter MANAGEMENT key — read-only, for the cost dashboard's Activity API (per-day spend). NEVER used for inference (would break model calls). Keep separate from OPENROUTER_API_KEY.
# ENABLE_OPENROUTER_EXACTO=true        # default ON: tool-bearing OpenRouter requests use :exacto quality routing (best tool-call providers). Set false to revert to Balanced.
# OPENROUTER_REQUIRE_PARAMETERS=true   # OPT-IN (default OFF since 2026-07-15): with exacto it over-filtered DeepSeek to 404 on every tool round. Exacto alone handles quality.
XAI_API_KEY=               # xAI direct (api.x.ai) — first-party serving for the Grok head (registry id xai-grok-4.20)
# AGENT_TURN_HARD_CAP_MS=280000        # Agent turn deadline. On a Pro plan with Fluid compute, raise chat route maxDuration + this together (e.g. 780000 with maxDuration 800).
# AGENT_LANGGRAPH_ROUTINE=true         # LangGraph deterministic routine lookups (sales/attendance/stock/pending): code runs the read tool, model only words the Bangla reply. Default: ON in preview, OFF in production. false = kill switch.
# AGENT_LANGGRAPH_CHECKPOINT=true      # LG-2 durable graph state (Postgres checkpointer on Supabase, schema "langgraph"). Default: ON in preview, OFF in production. false = kill switch. Uses DATABASE_URL; tables come from the Prisma migration.
# AGENT_LANGGRAPH_INTERRUPT=true       # LG-3 interrupt pilot: log_expense card staged as a paused graph thread; approve resumes it. Needs LG-2 checkpointer. Default: ON in preview, OFF in production. false = kill switch.
# AGENT_LANGGRAPH_TURN=shadow          # LG-4 turn graph, SHADOW mode: graph re-derives routing decisions, legacy executes, record logged on the route span. Default: ON in preview, OFF in production. false = kill switch.
# AGENT_LANGGRAPH_WORKFLOW=true        # LG-6 pilot: client SEO batch transitions mirrored into a durable graph thread (step history + replay). Needs LG-2 checkpointer. Default: ON in preview, OFF in production. false = kill switch.
# AGENT_LANGGRAPH_STORE=true           # LG-7: LangGraph BaseStore adapter over the EXISTING pgvector agent_memory (read/search via graph nodes; delete refused). Default: ON in preview, OFF in production. false = kill switch.
# ── Roadmap 1 (Phases 31-37) — independent kill switches, all behind AGENT_ENABLED ──
# AGENT_CONTINUITY_RESOLVER=shadow     # Phase 32 deterministic continuity resolver (message→work binding). off | shadow (decide+log only) | on. Default: ON in preview, SHADOW in production.
# AGENT_INTERACTION_LAYER=shadow       # Phase 36 human-behaviour layer (mode ladder, response contract, commitment ledger). off | shadow | on. Default: ON in preview, SHADOW in production.
# The 12-node owner-turn graph (Phase 33) rides AGENT_LANGGRAPH_TURN above (shadow = decides+compares, legacy executes).
# Rollout ladder stage lives in agent_kv_settings key `agent_graph_rollout_stage` (owner-tunable, no redeploy; default shadow) — see docs/agent-audit/phase-37-cutover.md.
# ── Roadmap 3 (Phases 51-58) — autonomy safety kernel. All OFF by default; enable ONE at a time after its readiness gate, recording who/scope/evidence/rollback (autonomy-slo recordEnablement). ──
# AGENT_EFFECT_ENGINE=true             # Phase 53: route direct write tools through the exactly-once effect engine (agent_action_runs + append-only ledger; ledger failure blocks the write) + starts the VPS outbox dispatcher and Phase 58 reconciler. Default OFF. Rollback: unset — writes run the legacy direct path again.
# AGENT_POINT_OF_RISK_ENFORCE=true     # Phase 52: enforce point-of-risk approval staging for owner-direct R3 writes (until then those decisions are shadow-logged). Default OFF; Phase 57 ladder promotes per task class instead of this global switch. Rollback: unset.
# Office Calling canonical sessions + encrypted native delivery registry. Keep the
# feature flag OFF until the current phase evidence passes. OFFICE_CALL_DEVICE_KEY
# is server-only; use a dedicated random secret (NEXTAUTH_SECRET is a compatibility
# fallback) and rotate it only with an explicit device re-registration plan.
# OFFICE_CALL_SESSIONS_ENABLED=true
# OFFICE_CALL_DEVICE_KEY=
# Emergency rollback for new call placement. Existing calls may still reconcile/end.
# OFFICE_CALLS_KILL_SWITCH=false
# Deterministic caller canary (0-100); 0 blocks new canonical calls, 100 allows all.
# OFFICE_CALL_ROLLOUT_PERCENT=100
# Server-enforced bounds. Code clamps unsafe values even if these are misconfigured.
# OFFICE_CALL_MAX_DURATION_MINUTES=120
# OFFICE_CALL_RATE_CALLER_PER_MINUTE=4
# OFFICE_CALL_RATE_CALLER_PER_TEN_MINUTES=20
# OFFICE_CALL_RATE_PAIR_PER_TEN_MINUTES=8
# OFFICE_CALL_RATE_EVENTS_PER_MINUTE=120
# Privacy retention (bounded in code): detailed events/delivery/device/session records.
# OFFICE_CALL_EVENT_RETENTION_DAYS=30
# OFFICE_CALL_DELIVERY_RETENTION_DAYS=30
# OFFICE_CALL_INVALID_DEVICE_RETENTION_DAYS=90
# OFFICE_CALL_SESSION_RETENTION_DAYS=365
# APNS_AUTH_KEY=
# APNS_KEY_ID=
# APNS_TEAM_ID=
# APNS_BUNDLE_ID=com.almatraders.erp
# FCM_SERVICE_ACCOUNT=
