NEXT_PUBLIC_API_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
API_SECRET=your-strong-secret-here

# Shared secret for almatraders.com → ERP order ingest (POST /api/orders/website)
WEBSITE_ORDER_SECRET=generate-a-long-random-secret-min-32-chars

# Hermes agent read-only orders API (GET /api/agent/orders/*)
# Same value as ALMA_ERP_API_KEY on Hermes VPS
ALMA_AGENT_API_KEY=

# Postgres (Supabase)
# Production (Vercel/serverless): use Transaction pooler on port 6543 — required for many short-lived connections.
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10"
# Local Prisma CLI (db push / migrate): use direct connection on port 5432, or add DIRECT_URL in schema.prisma.
# DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"

NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000
CRON_SECRET=generate-with-openssl-rand-base64-32
SESSION_MAX_AGE_SECONDS=2592000
NEXT_PUBLIC_ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=
ONESIGNAL_ANDROID_CHANNEL_ID=
RESEND_API_KEY=
EMAIL_FROM=Alma ERP <onboarding@resend.dev>

# Supabase Storage for private expense receipt/document uploads.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_EXPENSE_RECEIPTS_BUCKET=expense-receipts

# Optional public Supabase client values. Do not put service-role keys in NEXT_PUBLIC_* vars.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Alma Trading Telegram quick-entry bot (set in Vercel — never commit real tokens)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_RATE_LIMIT_PER_MINUTE=12
# BD hour (0-23) when prior-day PENDING drafts auto-lock (default 6)
TELEGRAM_DRAFT_LOCK_HOUR_BD=6
# Owner/admin Telegram chat IDs for ops alerts (comma-separated). DB settings take priority; this env is fallback.
# Also accepts legacy alias OWNER_TELEGRAM_CHAT_IDS. Example: 1949042834,987654321
TELEGRAM_OWNER_CHAT_IDS=
OWNER_TELEGRAM_CHAT_IDS=
# HMAC secret for Telegram sendPhoto preview URLs (defaults to TELEGRAM_WEBHOOK_SECRET / CRON_SECRET)
TELEGRAM_PREVIEW_SECRET=

# Sentry (production monitoring — set in Vercel, optional locally)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_PROFILES_SAMPLE_RATE=0
# Session Replay (only on error — never random sessions).
# Production default: 0.20 (20% of error-bearing sessions). 0 disables replay entirely.
SENTRY_REPLAY_SESSION_SAMPLE_RATE=0
SENTRY_REPLAY_ERROR_SAMPLE_RATE=0.2
# SENTRY_ENABLED=false
# SENTRY_DEBUG=true

# --- AGENT MODULE ---
# Kill switch: set to "true" in Vercel PREVIEW only to test. Keep "false" in production until owner approves.
AGENT_ENABLED=false
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=            # Whisper transcription (Phase 3)
GOOGLE_TTS_CREDENTIALS=    # path or JSON for bn-IN-Chirp3-HD-Charon (Phase 3/5)
# Phase 5 — NEW assistant bot (different token from the Hermes ERP bot above)
# Create via BotFather: /newbot → pick a name → copy the token here
ASSISTANT_BOT_TOKEN=       # e.g. 7654321098:AABBCCDDEEFFaabbccddeeff1122334455
TELEGRAM_OWNER_CHAT_ID=    # Your personal Telegram chat ID (send /start to @userinfobot to find it)
# ntfy push notifications — self-hosted on VPS recommended (https://ntfy.sh for quick start)
NTFY_SERVER=https://ntfy.sh          # or https://ntfy.yourdomain.com
NTFY_TOPIC_GENERAL=alma-agent        # Tier 1 general alerts topic
NTFY_TOPIC_CRITICAL=alma-agent-crit  # Tier 2 critical alerts topic (configure priority in ntfy app)
TWILIO_ACCOUNT_SID=        # Phase 5+
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=        # E.164 format, e.g. +14155551234
TWILIO_TO_NUMBER=          # Owner's phone number in E.164 format, e.g. +8801XXXXXXXXX
REDIS_URL=                 # VPS worker queue (Phase 4+)
AGENT_INTERNAL_TOKEN=      # Long random secret — worker→app callback auth (Phase 4+)
FB_PAGE_TOKEN_LIFESTYLE=   # Meta Graph API page token for Alma Lifestyle (Phase 4+)
FB_PAGE_TOKEN_ONLINESHOP=  # Meta Graph API page token for Alma Online Shop (Phase 4+)
