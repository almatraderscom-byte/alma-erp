ELEVENLABS_MODEL_ID=eleven_v3
ELEVENLABS_VOICE_STAFF=IKne3meq5aSn9XLyUdCD    # Charlie — staff announcements
ELEVENLABS_VOICE_MALE=IKne3meq5aSn9XLyUdCD     # Charlie — owner male / calls
ELEVENLABS_VOICE_FEMALE=SAz9YHcvj6GT2YYXdXww   # River — owner female (optional)
# ELEVENLABS_STABILITY=0.5
# ELEVENLABS_SIMILARITY_BOOST=0.75
# ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
# --- ElevenLabs Conversational AI outbound phone calls (two-way Bangla; family/friends/work) ---
# Kill switch — OFF by default. Set to true to let the agent place real phone calls.
VOICE_CALL_ENABLED=false
# Created in ElevenLabs dashboard → Conversational AI → Agents (Bangla language + your voice, enable overrides).
ELEVENLABS_AGENT_ID=
# ElevenLabs dashboard → Phone Numbers → import your Twilio number → copy the phone_number_id.
ELEVENLABS_AGENT_PHONE_NUMBER_ID=
# ElevenLabs dashboard → Conversational AI → Settings → Post-call webhook → copy the signing secret (wsec_...).
ELEVENLABS_WEBHOOK_SECRET=
# Safety caps (optional; sensible defaults applied in code).
# VOICE_CALL_DAILY_CAP=10            # max agent-placed calls per Dhaka day
# VOICE_CALL_MAX_MINUTES=10          # hint passed to the agent per call
# --- Two-way call engine switch ---
# elevenlabs (default, legacy ConvAI) | relay (Twilio ConversationRelay + Gemini +
# Google bn-IN-Chirp3-HD-Charon — the same voice as one-way calls, far better Bangla).
# VOICE_CALL_PROVIDER=relay
# Public wss URL of the VPS relay server (worker/src/voice-relay/server.mjs).
# Twilio REQUIRES TLS here — put the relay port behind HTTPS (Caddy/nginx/cloudflared).
# VOICE_RELAY_PUBLIC_WSS_URL=wss://relay.example.com/relay
# VOICE_RELAY_PORT=3100              # VPS-local port the relay listens on
# VOICE_RELAY_MODEL_ID=gemini-3.5-flash   # conversation brain (fast model = low turn latency)
# Phase 5 — NEW assistant bot (different token from the Hermes ERP bot above)
# Create via BotFather: /newbot → pick a name → copy the token here
ASSISTANT_BOT_TOKEN=       # e.g. 7654321098:AABBCCDDEEFFaabbccddeeff1122334455
TELEGRAM_OWNER_CHAT_ID=    # Your personal Telegram chat ID — MUST be set on VPS worker for shadow draft notifications (send /start to @userinfobot to find it)
TELEGRAM_STAFF_GROUP_CHAT_ID= # Office staff Telegram group chat id (negative number). Fallback for the idle-nudge target; preferred: set KV "idle_nudge_chat_id" (no redeploy). When idle alert is approved, the name-free reminder goes here.
# Imou camera — staff idle-detection pilot. Create a developer app at
# open.imoulife.com → My Application → Application Information for AppId/AppSecret,
# then bind the office camera. IMOU_DEVICE_ID = the bound camera's device id.
IMOU_APP_ID=               # e.g. lc116b5b6bcfe244e7
IMOU_APP_SECRET=           # keep secret — never commit the real value
IMOU_DEVICE_ID=            # bound camera device id (Work Room camera for the pilot)
# IMOU_API_BASE=https://openapi-sg.easy4ip.com/openapi   # Asia DC default; override per account region

# ntfy push notifications — self-hosted on VPS recommended (https://ntfy.sh for quick start)
NTFY_SERVER=https://ntfy.sh          # or https://ntfy.yourdomain.com
NTFY_TOPIC_GENERAL=alma-agent        # Tier 1 general alerts topic
NTFY_TOPIC_CRITICAL=alma-agent-crit  # Tier 2 critical alerts topic (configure priority in ntfy app)
TWILIO_ACCOUNT_SID=        # Phase 5+
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=        # E.164 format, e.g. +14155551234 — all non-salah outbound calls
TWILIO_TO_NUMBER=          # Owner's phone number in E.164 format, e.g. +8801XXXXXXXXX
# Dedicated OUTBOUND number for salah-reminder calls ONLY. Buy a second Twilio number on the
# same account. If unset, salah calls fall back to TWILIO_FROM_NUMBER.
# This number must NEVER be used for any non-salah call.
# Owner: leave inbound webhook blank/reject on this number (outbound-salah-only).
TWILIO_SALAH_FROM_NUMBER=
# Twilio WhatsApp — the business WhatsApp sender (reuses TWILIO_ACCOUNT_SID/AUTH_TOKEN above).
# Value = your Twilio WhatsApp number, e.g. whatsapp:+8801XXXXXXXXX (the "whatsapp:" prefix is optional).
TWILIO_WHATSAPP_FROM=
# Kill switch: WhatsApp send stays OFF until this is exactly "true" (even with creds set).
WHATSAPP_SEND_ENABLED=
# PUBLIC business WhatsApp number (digits only, e.g. 15559735455) for the staff
# home-page "WhatsApp-এ যুক্ত হন" opt-in button (wa.me deep link → staff sends a
# pre-written message → opens the 24h window). Unset = the button is hidden.
NEXT_PUBLIC_WA_BUSINESS_NUMBER=
# Kill switch: one-way WhatsApp VOICE calls stay OFF until this is exactly "true".
# Beyond this, WhatsApp requires Business Calling enabled on the sender AND the
# recipient to have granted call permission, or Twilio rejects the call.
WHATSAPP_CALL_ENABLED=
# Owner's WhatsApp number (e.g. +8801XXXXXXXXX). When set (+ WHATSAPP_SEND_ENABLED=true),
# the agent MIRRORS owner notifications/reminders to WhatsApp alongside Telegram.
# Free-form only delivers inside WhatsApp's 24h window (owner must have messaged the
# business number within 24h).
OWNER_WHATSAPP_NUMBER=
# Kill switch (VPS WORKER) for staff WhatsApp notifications — task dispatch / announcements
# also go to a staffer's WhatsApp (best-effort, only inside their 24h opt-in window).
# OFF until exactly "true". Needs TWILIO_WHATSAPP_FROM on the worker too. Default OFF.
STAFF_WHATSAPP_ENABLED=
# Office Live Intercom — Agora (agora-rtc-sdk-ng) app-to-app VOICE calling.
# Create a project at console.agora.io → Project Management. Enable the "App
# Certificate" (Primary Certificate) for token auth. Set BOTH on Vercel.
# The token route (/api/assistant/office/intercom/call-token) returns appId to the
# client, so NEXT_PUBLIC_AGORA_APP_ID is not strictly required — the placeholder is
# here only for clarity / optional client-side use.
AGORA_APP_ID=              # Agora project App ID
AGORA_APP_CERTIFICATE=     # Agora project App Certificate (Primary) — keep secret, never commit
NEXT_PUBLIC_AGORA_APP_ID=  # Optional: same App ID exposed to the client (not required)

REDIS_URL=                 # VPS worker queue (Phase 4+)
LONG_TASK_REDIS_URL=       # A2 background turns: CLOUD Redis (e.g. Upstash) reachable from BOTH Vercel AND the VPS worker. Required for >280s turns to hand off. Falls back to REDIS_URL. Set the SAME value on Vercel + worker.
AGENT_INTERNAL_TOKEN=      # Long random secret — worker→app callback auth (Phase 4+)
# Remote MCP "connector" (/api/assistant/mcp) — least-privilege bearer for an external Claude
# co-worker. SEPARATE secret from everything else (read-only, default-deny tool scope). Rotate
# independently. Leave blank to disable the connector entirely (route returns 401).
CONNECTOR_TOKEN=           # Long random secret — Bearer auth for the read-only Claude connector
FB_PAGE_TOKEN_LIFESTYLE=   # Meta Graph API page token for Alma Lifestyle — MUST be set on BOTH Vercel AND VPS worker (webhook runs on Vercel, sends run on worker)
FB_PAGE_TOKEN_ONLINESHOP=  # Meta Graph API page token for Alma Online Shop — MUST be set on BOTH Vercel AND VPS worker
# CS-1 — Messenger webhook (customer sales agent)
META_APP_ID=                # Meta App ID with Business Manager linked (e.g. 1990978398451639)
META_APP_SECRET=            # App Secret for META_APP_ID (X-Hub-Signature-256 validation)
META_WRONG_APP_IDS=         # Comma-separated legacy app IDs to unsubscribe from pages (e.g. 1561833048688297)
META_WEBHOOK_VERIFY_TOKEN=  # Custom verify token for webhook subscription
CS_STAFF_EYAFI_CHAT_ID=     # Optional: Eyafi Telegram chat for shadow drafts (falls back to DB agent_staff)
CS_AUTO_CONFIDENCE_THRESHOLD=0.72  # Live auto-reply minimum confidence (0-1). Below → escalate to human.
# Phase 4 — WhatsApp Cloud API (Coexistence, shadow mode first)
WA_PHONE_ID=               # WhatsApp Business phone_number_id from Meta
WA_TOKEN=                  # Permanent access token with whatsapp_business_messaging — Vercel + VPS
WA_VERIFY_TOKEN=           # Webhook verify token (falls back to META_WEBHOOK_VERIFY_TOKEN)
WA_WABA_ID=                # WhatsApp Business Account ID (template listing)
# Phase 6 — Ads monitoring (read-only, ads_read permission required)
META_ADS_TOKEN=            # Meta Marketing API access token with ads_read permission
META_AD_ACCOUNT_ID=        # Meta Ads account ID, e.g. act_1234567890
# Phase 6 — Schedulers kill switch (set to "true" on VPS worker to enable all scheduled jobs)
