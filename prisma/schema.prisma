generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  HR
  STAFF
  VIEWER
}

model User {
  id                 String                 @id @default(cuid())
  email              String?                @unique
  passwordHash       String
  name               String
  phone              String?                @unique
  role               UserRole               @default(STAFF)
  active             Boolean                @default(true)
  /// Comma-separated BusinessId: ALMA_LIFESTYLE,CREATIVE_DIGITAL_IT
  businessAccess     String                 @default("ALMA_LIFESTYLE,CREATIVE_DIGITAL_IT")
  employeeIdGas      String?
  joiningDate        DateTime?
  salaryHint         Decimal?               @db.Decimal(12, 2)
  profileImageUrl    String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  advanceRequests    SalaryAdvanceRequest[]
  passwordResetTokens PasswordResetToken[]
}

enum AdvanceStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EmployeeLedgerEntryType {
  SALARY_ACCRUAL
  ADVANCE
  WITHDRAWAL
  ADJUSTMENT
  BONUS
  PENALTY
}

enum WalletRequestType {
  ADVANCE
  WITHDRAWAL
}

enum WalletRequestStatus {
  PENDING
  APPROVED
  PARTIALLY_APPROVED
  REJECTED
}

enum PayrollAccrualRunStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

enum NotificationType {
  SALARY_ADDED
  ACCRUAL_FAILED
  WALLET_REQUEST_APPROVED
  WALLET_REQUEST_REJECTED
  ADMIN_ANNOUNCEMENT
  INVOICE_CREATED
  ORDER_ASSIGNED
  LOW_STOCK
  PAYROLL_ALERT
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum NotificationDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
}

model SalaryAdvanceRequest {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId    String
  amount        Decimal       @db.Decimal(12, 2)
  reason        String        @db.Text
  status        AdvanceStatus @default(PENDING)
  reviewedById  String?
  reviewNote    String?       @db.Text
  reviewedAt    DateTime?
  createdAt     DateTime      @default(now())

  @@index([status])
  @@index([userId])
}

model EmployeeLedgerEntry {
  id            String                  @id @default(cuid())
  employeeId    String
  userId        String?
  businessId    String
  date          DateTime
  periodYm      String?
  type          EmployeeLedgerEntryType
  amount        Decimal                 @db.Decimal(12, 2)
  note          String?                 @db.Text
  createdById   String?
  approvedById  String?
  source        String?
  sourceRef     String?
  walletRequestId String?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  @@unique([employeeId, businessId, periodYm, type])
  @@unique([source, sourceRef])
  @@index([employeeId, businessId, date])
  @@index([employeeId, businessId, periodYm])
  @@index([businessId, type])
  @@index([businessId, periodYm])
  @@index([userId])
}

model WalletRequest {
  id             String              @id @default(cuid())
  userId         String
  employeeId     String
  businessId     String
  type           WalletRequestType
  status         WalletRequestStatus @default(PENDING)
  requestedAmount Decimal            @db.Decimal(12, 2)
  approvedAmount  Decimal?           @db.Decimal(12, 2)
  reason         String              @db.Text
  reviewNote     String?             @db.Text
  reviewedById   String?
  reviewedAt     DateTime?
  ledgerEntryId  String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([status])
  @@index([userId])
  @@index([employeeId, businessId])
  @@index([businessId, type])
}

model PayrollAccrualRun {
  id          String                  @id @default(cuid())
  businessId  String
  periodYm    String
  trigger     String                  @default("manual")
  status      PayrollAccrualRunStatus
  employeeCount Int                   @default(0)
  createdCount  Int                   @default(0)
  skippedCount  Int                   @default(0)
  error       String?                 @db.Text
  runById     String?
  startedAt   DateTime                @default(now())
  finishedAt  DateTime?
  createdAt   DateTime                @default(now())

  @@unique([businessId, periodYm])
  @@index([status])
  @@index([businessId, createdAt])
}

model PayrollAutomationSetting {
  id                  String   @id @default("global")
  enabled             Boolean  @default(true)
  dayOfMonth           Int      @default(10)
  timezone            String   @default("Asia/Dhaka")
  retryAfterMinutes   Int      @default(60)
  notifyAdminsOnFailure Boolean @default(true)
  updatedById         String?
  updatedAt           DateTime @updatedAt
  createdAt           DateTime @default(now())
}

model Notification {
  id            String                @id @default(cuid())
  userId        String?
  roleTarget    UserRole?
  businessId    String?
  type          NotificationType
  priority      NotificationPriority  @default(NORMAL)
  title         String
  message       String                @db.Text
  actionUrl     String?
  pinned        Boolean               @default(false)
  readAt        DateTime?
  metadataJson  String?               @db.Text
  broadcastId   String?
  createdById   String?
  expiresAt     DateTime?
  createdAt     DateTime              @default(now())

  @@index([userId, readAt])
  @@index([roleTarget, readAt])
  @@index([businessId, createdAt])
  @@index([priority, createdAt])
  @@index([broadcastId])
  @@index([type])
}

model NotificationRecipient {
  id              String                     @id @default(cuid())
  notificationId  String
  userId          String
  businessId      String?
  deliveryStatus  NotificationDeliveryStatus @default(PENDING)
  pushStatus      String?
  emailStatus     String?
  emailMessageId  String?
  emailError      String?                    @db.Text
  emailSentAt     DateTime?
  deliveredAt     DateTime?
  seenAt          DateTime?
  readAt          DateTime?
  acknowledgedAt  DateTime?
  lastRemindedAt  DateTime?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  @@unique([notificationId, userId])
  @@index([userId, readAt])
  @@index([userId, acknowledgedAt])
  @@index([businessId, createdAt])
  @@index([deliveryStatus])
}

model NotificationBroadcast {
  id              String                @id @default(cuid())
  title           String
  message         String                @db.Text
  type            NotificationType      @default(ADMIN_ANNOUNCEMENT)
  priority        NotificationPriority  @default(NORMAL)
  target          String                @default("ALL")
  targetRole      UserRole?
  targetBusinessId String?
  targetUserId    String?
  actionUrl       String?
  pinned          Boolean               @default(false)
  createdById     String?
  createdAt       DateTime              @default(now())

  @@index([createdAt])
  @@index([target])
  @@index([targetBusinessId])
}

model PushSubscription {
  id             String   @id @default(cuid())
  userId         String
  provider       String   @default("onesignal")
  playerId       String?
  endpoint       String?
  platform       String?
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([provider, playerId])
  @@index([userId, enabled])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}
