  accountTitle      String?
  rawMessage        String                      @db.Text
  telegramMessageId String?
  telegramChatId    String
  tradeType         TradingTradeType?
  usdtAmount        Decimal?                    @db.Decimal(18, 8)
  bdtRate           Decimal?                    @db.Decimal(12, 4)
  feeUsdt           Decimal?                    @db.Decimal(18, 8)
