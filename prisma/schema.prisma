/// Owner-approved heuristics distilled from weekly reflection (correlation, not causation).
model AgentPlaybook {
  id           String    @id @default(uuid())
  businessId   String    @map("business_id")
  domain       String
  heuristic    String
  evidence     String
  confidence   Int       @default(2)
  status       String    @default("proposed")
  timesApplied Int       @default(0) @map("times_applied")
  createdAt    DateTime  @default(now()) @map("created_at")
  reviewedAt   DateTime? @map("reviewed_at")

  @@index([businessId, status])
  @@map("agent_playbook")
}

model AgentKnowledge {
  id            String   @id @default(uuid())
  entityType    String   @map("entity_type")
  entityId      String?  @map("entity_id")
  entityName    String?  @map("entity_name")
  attribute     String
  value         String   @db.Text
  confidence    Float    @default(0.5)
  evidenceCount Int      @default(1) @map("evidence_count")
  source        String?
  updatedAt     DateTime @updatedAt @map("updated_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([entityType, entityId, attribute])
  @@index([entityType])
  @@map("agent_knowledge")
}

// ─── PHASE 8: Cost dashboard ─────────────────────────────────────────────────

model AgentCostEvent {
  id             String   @id @default(uuid())
  provider       String
  kind           String
  units          Json     @default("{}")
  costUsd        Decimal  @map("cost_usd") @db.Decimal(10, 6)
