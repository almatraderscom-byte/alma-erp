  @@index([date, waqt])
  @@map("salah_overrides")
}

model AgentKvSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("agent_kv_settings")
}

// ─── PHASE 6: Finance ────────────────────────────────────────────────────────

model AgentFinanceExpense {
