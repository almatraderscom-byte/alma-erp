  returnRate   Float     @default(0) @map("return_rate")
  lastOrder    DateTime? @map("last_order") @db.Date
  daysInactive Float     @default(0) @map("days_inactive")
  favCategory  String    @default("") @map("fav_category")
  clvScore     Int       @default(0) @map("clv_score")
  riskScore    Int       @default(0) @map("risk_score")
  riskLevel    String    @default("LOW") @map("risk_level")
