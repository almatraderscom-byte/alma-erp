// ─── CS-1: Customer sales messenger agent ───────────────────────────────────

model CsConversation {
  id                    String          @id @default(uuid())
  pageId                String          @map("page_id")
  psid                  String          @map("psid")
  fbConversationId      String?         @map("fb_conversation_id")
  customerName          String?         @map("customer_name")
  mode                  String          @default("auto")
  status                String          @default("open")
  failedMatchCount      Int             @default(0) @map("failed_match_count")
  lastMessageAt         DateTime        @default(now()) @map("last_message_at")
  lastCustomerMessageAt DateTime?       @map("last_customer_message_at")
  lastCsReplyAt         DateTime?       @map("last_cs_reply_at")
  agentRepliesToday     Int             @default(0) @map("agent_replies_today")
  agentRepliesResetDate String?         @map("agent_replies_reset_date")
  abuseWarned           Boolean         @default(false) @map("abuse_warned")
  loopCount             Int             @default(0) @map("loop_count")
  lastQuestionHash      String?         @map("last_question_hash")
  lostSaleReason        String?         @map("lost_sale_reason")
  metadata              Json            @default("{}")
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")
  messages              CsMessage[]
  orderDrafts           CsOrderDraft[]
  shadowDrafts          CsShadowDraft[]
  replyJobs             CsReplyJob[]
  followups             CsFollowup[]

  @@unique([pageId, psid])
  @@index([lastMessageAt(sort: Desc)])
  @@index([status])
  @@map("cs_conversations")
}

model CsMessage {
  id             String         @id @default(uuid())
  conversationId String         @map("conversation_id")
