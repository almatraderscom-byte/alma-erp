  actorUserId  String?
  detail       String?                @db.Text
  metadataJson String?                @db.Text
  createdAt    DateTime               @default(now())

  @@index([businessId, action, createdAt])
  @@index([targetId, createdAt])
  @@index([actorUserId, createdAt])
}

model TradingVolumeTargetSettings {
  businessId            String   @id
  autoPenaltyEnabled    Boolean  @default(false)
  defaultPenaltyBdt     Decimal  @default(500) @db.Decimal(12, 2)
  updatedById           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

enum BusinessArchiveBatchStatus {
  PREVIEW
  COMPLETED
  RESTORED
  PARTIAL
}

model BusinessArchiveBatch {
  id                 String                     @id @default(cuid())
  name               String
  businessId         String
  moduleKeys         String
  status             BusinessArchiveBatchStatus @default(PREVIEW)
  recordCount        Int                        @default(0)
  dryRunSnapshot     String?                    @db.Text
  confirmationPhrase String?
  createdById        String
  createdAt          DateTime                   @default(now())
  completedAt        DateTime?
  restoredAt         DateTime?
  entities           BusinessArchiveEntity[]

  @@index([businessId, createdAt])
  @@index([status, createdAt])
}

model BusinessArchiveEntity {
  id           String               @id @default(cuid())
  batchId      String
  batch        BusinessArchiveBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  businessId   String
  moduleKey    String
  entityType   String
  entityId     String
  isArchived   Boolean              @default(true)
  archivedAt   DateTime             @default(now())
  archivedById String
  restoredAt   DateTime?
  restoredById String?

  @@unique([businessId, moduleKey, entityId])
  @@index([batchId])
  @@index([businessId, moduleKey, isArchived])
}

model BusinessArchiveAuditLog {
  id          String   @id @default(cuid())
  batchId     String?
  businessId  String
  action      String
  actorUserId String
  detailJson  String?  @db.Text
  createdAt   DateTime @default(now())

  @@index([businessId, createdAt])
  @@index([batchId, createdAt])
}

/// Hermes agent API audit trail — every write via /api/agent/* logs here.
/// Columns: actionType, resourceId, payload (jsonb), actor, ipAddress, createdAt
model AgentAuditLog {
  id         String   @id @default(cuid())
  actionType String
  resourceId String?
  payload    Json?
  actor      String   @default("agent_via_sir")
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([actionType, createdAt])
  @@index([createdAt])
  @@index([resourceId])
}

/// Agent-readable settings cache with version bump on PATCH.
model AgentSettings {
  id              String   @id @default("global")
  settingsVersion Int      @default(1)
  businessHours   Json?
  holidays        Json?
  lateThresholdMinutes Int @default(15)
  finePolicy      Json?
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
}

// ─── AGENT MODULE (Phase 0+) ────────────────────────────────────────────────
// These tables are owned exclusively by the agent module (src/agent/).
// ERP code must never import from src/agent/ or query these tables directly.

/// Top-level workspace for grouping agent conversations (e.g. ALMA Lifestyle, Trading, Personal).
model AgentProject {
  id                 String              @id @default(uuid())
  name               String
  description        String?
  systemInstructions String?             @db.Text
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  conversations      AgentConversation[]

  @@map("agent_projects")
}

/// A single conversation thread, optionally scoped to a project.
model AgentConversation {
  id        String          @id @default(uuid())
  projectId String?
  project   AgentProject?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  title     String?
  model     String?
  archived  Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  messages  AgentMessage[]
  artifacts AgentArtifact[]

  @@index([projectId])
  @@index([updatedAt(sort: Desc)])
  @@map("agent_conversations")
}

/// Individual turn in a conversation. content stores full Anthropic content blocks.
model AgentMessage {
  id             String            @id @default(uuid())
  conversationId String
  conversation   AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        Json
  tokensIn       Int?
  tokensOut      Int?
  costUsd        Decimal?          @db.Decimal(10, 6)
  usage          Json?
  createdAt      DateTime          @default(now())
  artifacts      AgentArtifact[]
  toolCalls      AgentToolCall[]

  @@index([conversationId, createdAt])
  @@map("agent_messages")
}

/// Rich output produced by the agent (code, markdown, HTML, images).
model AgentArtifact {
  id             String            @id @default(uuid())
  conversationId String
  conversation   AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  messageId      String?
  message        AgentMessage?     @relation(fields: [messageId], references: [id], onDelete: SetNull)
  type           String?
  title          String?
  content        String?           @db.Text
  version        Int               @default(1)
  createdAt      DateTime          @default(now())

  @@index([conversationId])
  @@index([messageId])
  @@map("agent_artifacts")
}

/// Owner's memory store. pgvector embedding column added in Phase 3.
model AgentMemory {
  id        String   @id @default(uuid())
  scope     String
  key       String?
  content   String   @db.Text
  pinned    Boolean  @default(false)
  metadata  Json?
  embedding Unsupported("vector(1536)")?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scope])
  @@map("agent_memory")
}

/// Execution record for every tool the agent invokes.
model AgentToolCall {
  id         String        @id @default(uuid())
  messageId  String?
  message    AgentMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  toolName   String
  input      Json?
  output     Json?
  status     String?
  durationMs Int?
  error      String?
  createdAt  DateTime      @default(now())

  @@index([messageId])
  @@map("agent_tool_calls")
}

/// Costly/destructive actions pending owner confirmation before execution.
model AgentPendingAction {
  id             String    @id @default(uuid())
  conversationId String?
  type           String
  payload        Json
  summary        String    @db.Text
  costEstimate   Float?
  status         String    @default("pending")
  createdAt      DateTime  @default(now())
  resolvedAt     DateTime?
  result         Json?

  @@index([status])
  @@index([conversationId])
  @@map("agent_pending_actions")
}

model AgentNotification {
  id         String   @id @default(uuid())
  tier       Int
  category   String?
  title      String   @db.Text
  message    String   @db.Text
  channels   Json
  statuses   Json
  createdAt  DateTime @default(now())

  @@index([tier])
  @@index([createdAt])
  @@map("agent_notifications")
}

// ─── PHASE 9: Personal Reminders ──────────────────────────────────────────────

model AgentReminder {
  id                   String    @id @default(uuid())
  title                String
  body                 String?   @db.Text
  dueAt                DateTime  @map("due_at")
  recurrenceRrule      String?   @map("recurrence_rrule")
  tier                 Int       @default(1)
  voice                Boolean   @default(true)
  status               String    @default("pending")
  snoozedUntil         DateTime? @map("snoozed_until")
  lastSentAt           DateTime? @map("last_sent_at")
  sendCount            Int       @default(0) @map("send_count")
  sourceConversationId String?   @map("source_conversation_id")
  createdAt            DateTime  @default(now()) @map("created_at")

  @@index([status, dueAt])
  @@index([dueAt])
  @@map("agent_reminders")
}

model AgentStaff {
  id             String       @id @default(uuid())
  name           String
  role           String
  telegramChatId String?
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  tasks          AgentStaffTask[]
  replyStats     AgentStaffReplyStat[]
  locations      AgentStaffLocation[]

  @@map("agent_staff")
}

// ─── PHASE 6: Staff Tasks ───────────────────────────────────────────────────

model AgentStaffTask {
  id               String    @id @default(uuid())
  staffId          String    @map("staff_id")
  staff            AgentStaff @relation(fields: [staffId], references: [id], onDelete: Cascade)
  title            String
  detail           String?   @db.Text
  type             String    @default("misc")
  productRef       String?   @map("product_ref")
  status           String    @default("proposed")
  proposedFor      DateTime  @map("proposed_for") @db.Date
  completedAt      DateTime? @map("completed_at")
  carriedFromTaskId String?  @map("carried_from_task_id")
  carriedFrom      AgentStaffTask?  @relation("CarryForward", fields: [carriedFromTaskId], references: [id], onDelete: SetNull)
  carriedTasks     AgentStaffTask[] @relation("CarryForward")
  source           String    @default("agent")
  createdAt        DateTime  @default(now()) @map("created_at")
  marketingHistory AgentProductMarketingHistory[]

  @@index([staffId])
  @@index([proposedFor, status])
  @@index([status])
  @@map("staff_tasks")
}

model AgentProductMarketingHistory {
  id             String    @id @default(uuid())
  productRef     String    @map("product_ref")
  business       String
  lastPromotedAt DateTime  @default(now()) @map("last_promoted_at")
  contentType    String?   @map("content_type")
  taskId         String?   @map("task_id")
  task           AgentStaffTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  notes          String?   @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([productRef, lastPromotedAt(sort: Desc)])
  @@index([business, lastPromotedAt(sort: Desc)])
  @@map("product_marketing_history")
}

// ─── PHASE 6: Salah ─────────────────────────────────────────────────────────

model AgentSalahRecord {
  id            String    @id @default(uuid())
  date          DateTime  @db.Date
  waqt          String
  windowStart   DateTime  @map("window_start")
  windowEnd     DateTime  @map("window_end")
  status        String    @default("pending")
  confirmedAt   DateTime? @map("confirmed_at")
  remindersSent Int       @default(0) @map("reminders_sent")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@unique([date, waqt])
  @@index([date(sort: Desc)])
  @@index([status])
  @@map("salah_records")
}

model AgentSalahOverride {
  id           String    @id @default(uuid())
  date         DateTime? @db.Date
  waqt         String?
  overrideTime DateTime? @map("override_time")
  delayUntil   DateTime? @map("delay_until")
  skip         Boolean   @default(false)
  reason       String?   @db.Text
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([date, waqt])
  @@map("salah_overrides")
}

model AgentKvSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("agent_kv_settings")
}

// ─── PHASE 6: Finance ────────────────────────────────────────────────────────

model AgentFinanceExpense {
  id         String   @id @default(uuid())
  amount     Int
  currency   String   @default("BDT")
  category   String?
  note       String?  @db.Text
  occurredAt DateTime @map("occurred_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([occurredAt(sort: Desc)])
  @@index([currency])
  @@map("finance_expenses")
}

model AgentFinanceLedger {
  id         String   @id @default(uuid())
  personName String   @map("person_name")
  direction  String
  amount     Int
  currency   String   @default("BDT")
  note       String?  @db.Text
  occurredAt DateTime @map("occurred_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([personName, occurredAt(sort: Desc)])
  @@index([direction])
  @@map("finance_ledger")
}

// ─── PHASE 6: Messenger Alerts ───────────────────────────────────────────────

model AgentMessengerAlert {
  id             String    @id @default(uuid())
  pageId         String    @map("page_id")
  conversationId String    @map("conversation_id")
  alertType      String    @map("alert_type")
  detectedAt     DateTime  @default(now()) @map("detected_at")
  detectedDate   DateTime  @default(now()) @map("detected_date") @db.Date
  resolved       Boolean   @default(false)
  resolvedAt     DateTime? @map("resolved_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@unique([conversationId, alertType, detectedDate])
  @@index([pageId, detectedAt(sort: Desc)])
  @@index([resolved, detectedAt(sort: Desc)])
  @@map("messenger_alerts")
}

// ─── PHASE 7: Watchdog heartbeats ────────────────────────────────────────────

model AgentHeartbeat {
  service    String   @id
  lastBeatAt DateTime @default(now()) @map("last_beat_at")

  @@map("agent_heartbeats")
}

// ─── PHASE 8: Cost dashboard ─────────────────────────────────────────────────

model AgentCostEvent {
  id             String   @id @default(uuid())
  provider       String
  kind           String
  units          Json     @default("{}")
  costUsd        Decimal  @map("cost_usd") @db.Decimal(10, 6)
  conversationId String?  @map("conversation_id")
  jobId          String?  @map("job_id")
  dedupKey       String?  @unique @map("dedup_key")
  occurredAt     DateTime @default(now()) @map("occurred_at")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([occurredAt(sort: Desc)])
  @@index([provider, occurredAt(sort: Desc)])
  @@index([conversationId])
  @@map("agent_cost_events")
}

model AgentSubscription {
  id            String   @id @default(uuid())
  name          String
  amount        Decimal  @db.Decimal(10, 2)
  currency      String   @default("USD")
  billingCycle  String   @map("billing_cycle")
  nextRenewalAt DateTime @map("next_renewal_at") @db.Date
  category      String?
  notes         String?  @db.Text
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([nextRenewalAt])
  @@index([active])
  @@map("agent_subscriptions")
}

// ─── PHASE 10: ask_user, reply stats, staff GPS ─────────────────────────────

model AgentAskCard {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  question       String   @db.Text
  options        String   @db.Text
  status         String   @default("pending")
  selectedOption String?  @map("selected_option")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([conversationId, status])
  @@map("agent_ask_cards")
}

model AgentStaffReplyStat {
  id             String    @id @default(uuid())
  staffId        String?   @map("staff_id")
  staff          AgentStaff? @relation(fields: [staffId], references: [id], onDelete: SetNull)
  pageId         String    @map("page_id")
  conversationId String    @map("conversation_id")
  customerMsgAt  DateTime  @map("customer_msg_at")
  firstReplyAt   DateTime  @map("first_reply_at")
  replyMinutes   Int       @map("reply_minutes")
  date           DateTime  @db.Date
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([staffId, date])
  @@index([date])
  @@map("staff_reply_stats")
}

model AgentStaffLocation {
  id         String   @id @default(uuid())
  staffId    String   @map("staff_id")
  staff      AgentStaff @relation(fields: [staffId], references: [id], onDelete: Cascade)
  lat        Float
  lng        Float
  accuracy   Float?
  recordedAt DateTime @map("recorded_at")
  source     String
  metadata   String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([staffId, recordedAt(sort: Desc)])
  @@map("staff_locations")
}
