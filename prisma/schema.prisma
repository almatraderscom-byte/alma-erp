  tradingTradeId    String?
  postedAt          DateTime?
  reviewedBy        String?
  reviewedAt        DateTime?
  lastEditedBy      String?
  lastEditedAt      DateTime?
  rejectReason      String?                     @db.Text
  /// Per-user daily sequence (resets each BD calendar day), not shared across staff.
  tradeNumber       Int?
  /// Hash for duplicate detection scoped to telegramUserId + account + day.
