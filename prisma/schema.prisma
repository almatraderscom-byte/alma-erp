generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  HR
  STAFF
  VIEWER
}

model User {
  id                            String                           @id @default(cuid())
  email                         String?                          @unique
  passwordHash                  String
  name                          String
  phone                         String?                          @unique
  role                          UserRole                         @default(STAFF)
  active                        Boolean                          @default(true)
  /// Comma-separated BusinessId: ALMA_LIFESTYLE,CREATIVE_DIGITAL_IT,ALMA_TRADING
  businessAccess                String                           @default("ALMA_LIFESTYLE,CREATIVE_DIGITAL_IT,ALMA_TRADING")
  employeeIdGas                 String?
  joiningDate                   DateTime?
  salaryHint                    Decimal?                         @db.Decimal(12, 2)
  profileImageUrl               String?
  createdAt                     DateTime                         @default(now())
  updatedAt                     DateTime                         @updatedAt
  advanceRequests               SalaryAdvanceRequest[]
  mealAllowanceProfiles         MealAllowanceProfile[]
  mealAllowanceRequests         MealAllowanceRequest[]
  passwordResetTokens           PasswordResetToken[]
  assignedTradingAccounts       TradingAccount[]                 @relation("TradingAccountAssignedUser")
  tradingTrades                 TradingTrade[]                   @relation("TradingTradeUser")
  tradingExpensesCreated        TradingExpense[]                 @relation("TradingExpenseCreatedBy")
  tradingPartnershipSettlements TradingPartnershipSettlement[]   @relation("TradingPartnershipSettledBy")
  tradingCapitalCreated         TradingCapitalEntry[]            @relation("TradingCapitalCreatedBy")
  tradingBkashCreated           TradingBkashDailySummary[]       @relation("TradingBkashSummaryCreatedBy")
  tradingPerformanceShots       TradingPerformanceScreenshot[]   @relation("TradingPerformanceUploadedBy")
  tradingEmployeeProfile        TradingEmployeeProfile?          @relation("TradingEmployeeProfileUser")
  tradingDailyReports           TradingEmployeeDailyReport[]     @relation("TradingEmployeeDailyReportUser")
  attendanceRecords             AttendanceRecord[]               @relation("AttendanceRecordUser")
  attendanceWaivers             AttendanceWaiverRequest[]        @relation("AttendanceWaiverRequester")
  attendanceReviews             AttendanceWaiverRequest[]        @relation("AttendanceWaiverReviewer")
  attendanceSelfies             AttendanceSelfieVerification[]   @relation("AttendanceSelfieUser")
  tradingTelegramLinks          TradingTelegramUser[]            @relation("TradingTelegramErpUser")
  tradingTelegramDrafts         TradingTelegramDraft[]           @relation("TradingTelegramDraftErpUser")
  operationalTasksCreated       OperationalTask[]                @relation("OperationalTaskCreator")
  operationalTaskAssignments    OperationalTaskAssignment[]      @relation("OperationalTaskAssignee")
  operationalTaskAcks           OperationalTaskAcknowledgement[] @relation("OperationalTaskAckUser")
  paymentMethods                EmployeePaymentMethod[]          @relation("UserPaymentMethods")
  agentStaffLinks               AgentStaff[]                     @relation("AgentStaffUser")

  @@index([active, role])
  @@index([active, createdAt])
  @@index([employeeIdGas])
  @@index([businessAccess])
}

enum AdvanceStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EmployeeLedgerEntryType {
  SALARY_ACCRUAL
  ADVANCE
  WITHDRAWAL
  ADJUSTMENT
  COMMISSION
  EID_BONUS
  PERFORMANCE_BONUS
  MEAL_DEDUCTION
  MEAL_ALLOWANCE
  OVERTIME
  REIMBURSEMENT
  /// Legacy generic bonus rows are still readable; new compensation should use specific bonus types.
  BONUS
  PENALTY
}

enum WalletRequestType {
  ADVANCE
  WITHDRAWAL
}

enum WalletRequestStatus {
  PENDING
  APPROVED
  PARTIALLY_APPROVED
  REJECTED
}

enum AttendanceRecordStatus {
  PRESENT
  LATE
  COMPLETED
  EARLY_LEAVE
}

enum AttendanceWaiverStatus {
  PENDING
  APPROVED
  PARTIALLY_APPROVED
  REJECTED
  CANCELLED
}

enum AttendanceWaiverRequestType {
  FULL_WAIVE
  PARTIAL_REDUCE
  RECONSIDERATION
}

enum AttendanceTrustStatus {
  TRUSTED
  WARNING
  REQUIRES_VERIFICATION
}

enum PayrollAccrualRunStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

enum NotificationType {
  SALARY_ADDED
  ACCRUAL_FAILED
  WALLET_REQUEST_APPROVED
  WALLET_REQUEST_REJECTED
  ADMIN_ANNOUNCEMENT
  INVOICE_CREATED
  ORDER_ASSIGNED
  LOW_STOCK
  PAYROLL_ALERT
  EXPENSE_ADDED
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum NotificationDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum InvoicePaymentStatus {
  UNPAID
  PARTIAL
  PAID
  VOID
}

enum InvoiceEventType {
  CREATED
  REGENERATED
  OPENED
  SHARED
  DELETED
}

enum TradingAccountStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CLOSED
}

enum TradingAccountType {
  BINANCE_P2P
  MERCHANT
  STAFF_OPERATED
  OTHER
}

enum TradingCapitalEntryType {
  DEPOSIT
  WITHDRAW
  ADJUSTMENT
}

enum TradingTradeType {
  BUY
  SELL
}

enum TradingCommissionType {
  NONE
  PERCENTAGE
  FIXED
}

enum TradingExpensePaidBy {
  OWNER
  STAFF
}

model SalaryAdvanceRequest {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId   String
  amount       Decimal       @db.Decimal(12, 2)
  reason       String        @db.Text
  status       AdvanceStatus @default(PENDING)
  reviewedById String?
  reviewNote   String?       @db.Text
  reviewedAt   DateTime?
  createdAt    DateTime      @default(now())

  @@index([status])
  @@index([userId])
}

model EmployeeLedgerEntry {
  id              String                  @id @default(cuid())
  employeeId      String
  userId          String?
  businessId      String
  date            DateTime
  periodYm        String?
  type            EmployeeLedgerEntryType
  amount          Decimal                 @db.Decimal(12, 2)
  note            String?                 @db.Text
  createdById     String?
  approvedById    String?
  source          String?
  sourceRef       String?
  walletRequestId String?
  isArchived      Boolean                 @default(false)
  archivedAt      DateTime?
  archivedById    String?
  archiveBatchId  String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@unique([employeeId, businessId, periodYm, type])
  @@unique([source, sourceRef])
  @@index([businessId, isArchived, createdAt])
  @@index([employeeId, businessId, date])
  @@index([employeeId, businessId, periodYm])
  @@index([businessId, type])
  @@index([businessId, periodYm])
  @@index([businessId, createdAt])
  @@index([businessId, employeeId, createdAt])
  @@index([userId])
}

enum EmployeePaymentMethodType {
  MOBILE_BANKING
  BANK_ACCOUNT
}

enum MobileMoneyProvider {
  BKASH
  NAGAD
  ROCKET
  OTHER
}

enum PaymentAccountUsage {
  PERSONAL
  BUSINESS
}

enum PaymentMethodStatus {
  ACTIVE
  DISABLED
  SUSPICIOUS
  ARCHIVED
}

model EmployeePaymentMethod {
  id                String                          @id @default(cuid())
  userId            String
  user              User                            @relation("UserPaymentMethods", fields: [userId], references: [id], onDelete: Cascade)
  businessId        String
  type              EmployeePaymentMethodType
  provider          MobileMoneyProvider?
  usageType         PaymentAccountUsage?
  accountHolderName String
  accountNumber     String
  bankName          String?
  branchName        String?
  routingNumber     String?
  qrImageUrl        String?                         @db.Text
  isPrimary         Boolean                         @default(false)
  isVerified        Boolean                         @default(false)
  verifiedAt        DateTime?
  verifiedById      String?
  status            PaymentMethodStatus             @default(ACTIVE)
  suspiciousNote    String?                         @db.Text
  isArchived        Boolean                         @default(false)
  archivedAt        DateTime?
  createdAt         DateTime                        @default(now())
  updatedAt         DateTime                        @updatedAt
  auditLogs         EmployeePaymentMethodAuditLog[]

  @@index([userId, businessId, isArchived])
  @@index([userId, isPrimary])
  @@index([businessId, status])
}

model EmployeePaymentMethodAuditLog {
  id              String                 @id @default(cuid())
  paymentMethodId String?
  paymentMethod   EmployeePaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  userId          String
  businessId      String
  actorUserId     String
  action          String
  detailJson      String?                @db.Text
  createdAt       DateTime               @default(now())

  @@index([userId, createdAt])
  @@index([paymentMethodId, createdAt])
}

model WalletRequest {
  id              String              @id @default(cuid())
  userId          String
  employeeId      String
  businessId      String
  type            WalletRequestType
  status          WalletRequestStatus @default(PENDING)
  requestedAmount Decimal             @db.Decimal(12, 2)
  approvedAmount  Decimal?            @db.Decimal(12, 2)
  reason          String              @db.Text
  paymentMethodId String?
  reviewNote      String?             @db.Text
  reviewedById    String?
  reviewedAt      DateTime?
  ledgerEntryId   String?
  isArchived      Boolean             @default(false)
  archivedAt      DateTime?
  archivedById    String?
  archiveBatchId  String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([businessId, isArchived, createdAt])
  @@index([status])
  @@index([userId])
  @@index([employeeId, businessId])
  @@index([businessId, type])
  @@index([businessId, status, createdAt])
  @@index([userId, status, createdAt])
}

model MealAllowanceProfile {
  id          String   @id @default(cuid())
  userId      String
  businessId  String
  employeeId  String
  enabled     Boolean  @default(false)
  amountBdt   Decimal  @db.Decimal(12, 2)
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@index([businessId])
}

model MealAllowanceRequest {
  id            String   @id @default(cuid())
  userId        String
  businessId    String
  employeeId    String
  allowanceDate DateTime
  amountBdt     Decimal  @db.Decimal(12, 2)
  reason        String   @db.Text
  status        String   @default("PENDING")
  ledgerEntryId String?
  reviewedById  String?
  approvalId    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([businessId, status])
  @@index([userId, businessId])
  @@index([userId, businessId, allowanceDate])
}

model AttendanceRecord {
  id                             String                         @id @default(cuid())
  businessId                     String
  userId                         String
  user                           User                           @relation("AttendanceRecordUser", fields: [userId], references: [id], onDelete: Cascade)
  employeeId                     String
  attendanceDate                 DateTime
  status                         AttendanceRecordStatus         @default(PRESENT)
  officeStartMinutes             Int                            @default(540)
  officeEndMinutes               Int                            @default(1260)
  checkInAt                      DateTime
  checkOutAt                     DateTime?
  totalWorkMinutes               Int                            @default(0)
  lateMinutes                    Int                            @default(0)
  penaltyAmount                  Decimal                        @default(0) @db.Decimal(12, 2)
  penaltyLedgerEntryId           String?
  earlyLeaveMinutes              Int?
  earlyLeavePenaltyAmount        Decimal?                       @db.Decimal(12, 2)
  earlyLeavePenaltyLedgerEntryId String?
  deviceInfo                     String?                        @db.Text
  sessionInfo                    String?                        @db.Text
  ipHash                         String?
  browserFingerprint             String?
  deviceKey                      String?
  sessionId                      String?
  latitude                       Decimal?                       @db.Decimal(10, 7)
  longitude                      Decimal?                       @db.Decimal(10, 7)
  locationAccuracyM              Int?
  distanceFromOfficeM            Int?
  trustStatus                    AttendanceTrustStatus          @default(TRUSTED)
  suspiciousReasons              String[]
  verificationRequired           Boolean                        @default(false)
  verificationRequestedById      String?
  /// Front-camera face verification at check-in (lightweight thumb only stored).
  faceVerified                   Boolean                        @default(false)
  faceVerifiedAt                 DateTime?
  faceThumbDataUrl               String?                        @db.Text
  isArchived                     Boolean                        @default(false)
  archivedAt                     DateTime?
  archivedById                   String?
  archiveBatchId                 String?
  createdAt                      DateTime                       @default(now())
  updatedAt                      DateTime                       @updatedAt
  waiverRequests                 AttendanceWaiverRequest[]
  selfieVerifications            AttendanceSelfieVerification[]

  @@unique([businessId, employeeId, attendanceDate])
  @@index([businessId, isArchived, attendanceDate])
  @@index([businessId, attendanceDate])
  @@index([userId, attendanceDate])
  @@index([businessId, status, attendanceDate])
  @@index([businessId, trustStatus, attendanceDate])
  @@index([businessId, verificationRequired, attendanceDate])
  @@index([businessId, employeeId, attendanceDate])
  @@index([businessId, userId, attendanceDate])
  @@index([businessId, employeeId, deviceKey])
  @@index([businessId, checkInAt])
  @@index([penaltyLedgerEntryId])
}

model AttendanceSelfieVerification {
  id                 String           @id @default(cuid())
  attendanceRecordId String
  attendanceRecord   AttendanceRecord @relation(fields: [attendanceRecordId], references: [id], onDelete: Cascade)
  businessId         String
  userId             String
  user               User             @relation("AttendanceSelfieUser", fields: [userId], references: [id], onDelete: Cascade)
  employeeId         String
  deviceKey          String?
  imageDataUrl       String           @db.Text
  contentType        String           @default("image/jpeg")
  sizeBytes          Int              @default(0)
  capturedAt         DateTime         @default(now())
  reviewedAt         DateTime?
  reviewedById       String?
  reviewNote         String?          @db.Text
  createdAt          DateTime         @default(now())

  @@index([businessId, capturedAt])
  @@index([businessId, employeeId, capturedAt])
  @@index([attendanceRecordId, capturedAt])
  @@index([userId])
}

model AttendanceWaiverRequest {
  id                       String                      @id @default(cuid())
  attendanceRecordId       String
  attendanceRecord         AttendanceRecord            @relation(fields: [attendanceRecordId], references: [id], onDelete: Cascade)
  businessId               String
  userId                   String
  requester                User                        @relation("AttendanceWaiverRequester", fields: [userId], references: [id], onDelete: Cascade)
  employeeId               String
  status                   AttendanceWaiverStatus      @default(PENDING)
  requestType              AttendanceWaiverRequestType @default(FULL_WAIVE)
  originalPenaltyAmount    Decimal                     @default(0) @db.Decimal(12, 2)
  requestedReductionAmount Decimal?                    @db.Decimal(12, 2)
  approvedReductionAmount  Decimal?                    @db.Decimal(12, 2)
  reason                   String                      @db.Text
  attachmentDataUrl        String?                     @db.Text
  adminNote                String?                     @db.Text
  reviewedById             String?
  reviewer                 User?                       @relation("AttendanceWaiverReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt               DateTime?
  reversalLedgerEntryId    String?
  isArchived               Boolean                     @default(false)
  archivedAt               DateTime?
  archivedById             String?
  archiveBatchId           String?
  createdAt                DateTime                    @default(now())
  updatedAt                DateTime                    @updatedAt

  @@unique([attendanceRecordId, userId])
  @@index([businessId, isArchived, createdAt])
  @@index([businessId, status, createdAt])
  @@index([businessId, employeeId, createdAt])
  @@index([businessId, userId, createdAt])
  @@index([reviewedById])
  @@index([reversalLedgerEntryId])
}

model PayrollAccrualRun {
  id            String                  @id @default(cuid())
  businessId    String
  periodYm      String
  trigger       String                  @default("manual")
  status        PayrollAccrualRunStatus
  employeeCount Int                     @default(0)
  createdCount  Int                     @default(0)
  skippedCount  Int                     @default(0)
  error         String?                 @db.Text
  runById       String?
  startedAt     DateTime                @default(now())
  finishedAt    DateTime?
  createdAt     DateTime                @default(now())

  @@unique([businessId, periodYm])
  @@index([status])
  @@index([businessId, createdAt])
}

model PayrollAutomationSetting {
  id                    String   @id @default("global")
  enabled               Boolean  @default(true)
  dayOfMonth            Int      @default(10)
  timezone              String   @default("Asia/Dhaka")
  retryAfterMinutes     Int      @default(60)
  notifyAdminsOnFailure Boolean  @default(true)
  updatedById           String?
  updatedAt             DateTime @updatedAt
  createdAt             DateTime @default(now())
}

model PayrollCompensationSetting {
  id                               String   @id @default(cuid())
  businessId                       String   @unique
  commissionEnabled                Boolean  @default(true)
  commissionMode                   String   @default("FIXED")
  fixedCommissionPerDeliveredOrder Decimal  @default(0) @db.Decimal(12, 2)
  percentageCommissionRate         Decimal? @db.Decimal(6, 3)
  largeBonusAlertThreshold         Decimal  @default(10000) @db.Decimal(12, 2)
  abnormalPenaltyAlertThreshold    Decimal  @default(5000) @db.Decimal(12, 2)
  updatedById                      String?
  createdAt                        DateTime @default(now())
  updatedAt                        DateTime @updatedAt

  @@index([businessId])
}

model InvoiceRecord {
  id              String               @id @default(cuid())
  invoiceNumber   String
  orderId         String
  customerName    String
  customerPhone   String?
  businessId      String
  amount          Decimal              @db.Decimal(12, 2)
  paymentStatus   InvoicePaymentStatus @default(UNPAID)
  driveUrl        String?              @db.Text
  fileUrl         String?              @db.Text
  shareUrl        String?              @db.Text
  fileName        String?
  generatedById   String?
  generatedByName String?
  isArchived      Boolean              @default(false)
  archivedAt      DateTime?
  archivedById    String?
  archiveBatchId  String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  deletedAt       DateTime?
  events          InvoiceEvent[]

  @@unique([businessId, orderId])
  @@unique([businessId, invoiceNumber])
  @@index([businessId, isArchived, createdAt])
  @@index([businessId, createdAt])
  @@index([businessId, paymentStatus])
  @@index([businessId, customerPhone])
  @@index([businessId, deletedAt, createdAt])
  @@index([orderId])
}

model InvoiceEvent {
  id           String           @id @default(cuid())
  invoiceId    String
  invoice      InvoiceRecord    @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  type         InvoiceEventType
  actorId      String?
  actorName    String?
  note         String?          @db.Text
  metadataJson String?          @db.Text
  createdAt    DateTime         @default(now())

  @@index([invoiceId, createdAt])
  @@index([type, createdAt])
}

model ExpenseAttachment {
  id             String    @id @default(cuid())
  expenseId      String?
  businessId     String
  bucket         String
  objectPath     String    @unique
  originalName   String
  contentType    String
  sizeBytes      Int
  publicUrl      String?   @db.Text
  uploadedById   String?
  uploadedByName String?
  uploadedAt     DateTime  @default(now())
  deletedAt      DateTime?

  @@index([businessId, uploadedAt])
  @@index([expenseId])
  @@index([uploadedById])
}

model Notification {
  id           String               @id @default(cuid())
  userId       String?
  roleTarget   UserRole?
  businessId   String?
  type         NotificationType
  priority     NotificationPriority @default(NORMAL)
  title        String
  message      String               @db.Text
  actionUrl    String?
  pinned       Boolean              @default(false)
  readAt       DateTime?
  metadataJson String?              @db.Text
  broadcastId  String?
  createdById  String?
  expiresAt    DateTime?
  createdAt    DateTime             @default(now())

  @@index([userId, readAt])
  @@index([roleTarget, readAt])
  @@index([businessId, createdAt])
  @@index([businessId, type, createdAt])
  @@index([businessId, priority, createdAt])
  @@index([userId, createdAt])
  @@index([roleTarget, createdAt])
  @@index([priority, createdAt])
  @@index([broadcastId])
  @@index([type])
}

model ApprovalRequest {
  id              String               @id @default(cuid())
  module          String
  type            String
  businessId      String?
  entityId        String
  requestedBy     String
  approvedBy      String?
  rejectedBy      String?
  reason          String               @db.Text
  payloadSnapshot Json?
  status          ApprovalStatus       @default(PENDING)
  priority        NotificationPriority @default(NORMAL)
  actionUrl       String?
  auditHistory    Json?
  isArchived      Boolean              @default(false)
  archivedAt      DateTime?
  archivedById    String?
  archiveBatchId  String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  approvedAt      DateTime?
  rejectedAt      DateTime?

  @@index([businessId, isArchived, createdAt])
  @@index([status, createdAt])
  @@index([module, status, createdAt])
  @@index([businessId, status, createdAt])
  @@index([priority, status, createdAt])
  @@index([entityId])
  @@index([requestedBy, status])
  @@index([requestedBy, status, createdAt])
  @@index([approvedBy])
  @@index([rejectedBy])
}

model NotificationRecipient {
  id             String                     @id @default(cuid())
  notificationId String
  userId         String
  businessId     String?
  deliveryStatus NotificationDeliveryStatus @default(PENDING)
  pushStatus     String?
  emailStatus    String?
  emailMessageId String?
  emailError     String?                    @db.Text
  emailSentAt    DateTime?
  deliveredAt    DateTime?
  seenAt         DateTime?
  readAt         DateTime?
  acknowledgedAt DateTime?
  lastRemindedAt DateTime?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  @@unique([notificationId, userId])
  @@index([userId, readAt])
  @@index([userId, acknowledgedAt])
  @@index([userId, businessId, readAt])
  @@index([userId, businessId, acknowledgedAt])
  @@index([userId, businessId, createdAt])
  @@index([userId, createdAt])
  @@index([notificationId, readAt])
  @@index([notificationId, seenAt])
  @@index([notificationId, acknowledgedAt])
  @@index([acknowledgedAt, deliveredAt, lastRemindedAt])
  @@index([businessId, createdAt])
  @@index([deliveryStatus])
}

model NotificationBroadcast {
  id               String               @id @default(cuid())
  title            String
  message          String               @db.Text
  type             NotificationType     @default(ADMIN_ANNOUNCEMENT)
  priority         NotificationPriority @default(NORMAL)
  target           String               @default("ALL")
  targetRole       UserRole?
  targetBusinessId String?
  targetUserId     String?
  actionUrl        String?
  pinned           Boolean              @default(false)
  createdById      String?
  createdAt        DateTime             @default(now())

  @@index([createdAt])
  @@index([target])
  @@index([targetBusinessId])
}

model PushSubscription {
  id             String    @id @default(cuid())
  userId         String
  provider       String    @default("onesignal")
  playerId       String?
  endpoint       String?
  externalUserId String?
  businessId     String?
  role           String?
  employeeIdGas  String?
  platform       String?
  userAgent      String?   @db.Text
  enabled        Boolean   @default(true)
  lastSeenAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([provider, playerId])
  @@index([userId, enabled])
  @@index([businessId, enabled])
  @@index([role, enabled])
  @@index([employeeIdGas])
}

model SmsLog {
  id            String    @id @default(cuid())
  businessId    String?
  phone         String
  message       String    @db.Text
  type          String
  provider      String    @default("sms.net.bd")
  requestId     String?
  status        String    @default("QUEUED")
  errorCode     String?
  errorMessage  String?   @db.Text
  attempts      Int       @default(0)
  nextAttemptAt DateTime?
  sentAt        DateTime?
  deliveredAt   DateTime?
  metadataJson  String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([createdAt])
  @@index([phone])
  @@index([status])
  @@index([businessId])
  @@index([businessId, type, phone, createdAt])
  @@index([requestId])
}

model SmsSetting {
  id               String   @id @default(cuid())
  businessId       String   @unique
  enabled          Boolean  @default(false)
  senderId         String?
  enabledTypesJson String?  @db.Text
  updatedById      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([enabled])
}

model TradingAccount {
  id                               String                         @id @default(cuid())
  businessId                       String
  assignedUserId                   String?
  assignedUser                     User?                          @relation("TradingAccountAssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)
  accountTitle                     String
  binanceUid                       String?
  accountType                      TradingAccountType             @default(BINANCE_P2P)
  status                           TradingAccountStatus           @default(ACTIVE)
  startingCapital                  Decimal                        @default(0) @db.Decimal(14, 2)
