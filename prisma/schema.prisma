  actorUserId        String?
  employeeId         String?
  attendanceRecordId String?
  detail             String?  @db.Text
  metadataJson       String?  @db.Text
  createdAt          DateTime @default(now())

  @@index([businessId, eventType, createdAt])
  @@index([employeeId, createdAt])
  @@index([attendanceRecordId])
}

enum TradingVolumeTargetStatus {
  PENDING
  MET
  MISSED
  IGNORED
}

enum TradingVolumeTargetPenaltyStatus {
  PENDING
  APPLIED
  PARTIALLY_WAIVED
  WAIVED
  REJECTED
}

model TradingDailyVolumeTarget {
  id               String                       @id @default(cuid())
  businessId       String
  tradingAccountId String
  tradingAccount   TradingAccount               @relation(fields: [tradingAccountId], references: [id], onDelete: Restrict)
  targetDate       DateTime
  targetUsdt       Decimal                      @db.Decimal(18, 8)
  actualUsdt       Decimal                      @default(0) @db.Decimal(18, 8)
  status           TradingVolumeTargetStatus    @default(PENDING)
  penaltyAmountBdt Decimal?                     @db.Decimal(12, 2)
  setById          String
  notes            String?                      @db.Text
  ignoredById      String?
  ignoredAt        DateTime?
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt
  penalties        TradingVolumeTargetPenalty[]
  audits           TradingVolumeTargetAudit[]

  @@unique([tradingAccountId, targetDate])
  @@index([businessId, targetDate])
  @@index([businessId, status, targetDate])
  @@index([tradingAccountId, targetDate])
}

model TradingVolumeTargetPenalty {
  id                    String                           @id @default(cuid())
  targetId              String
  target                TradingDailyVolumeTarget         @relation(fields: [targetId], references: [id], onDelete: Cascade)
  businessId            String
  employeeId            String
  userId                String?
  status                TradingVolumeTargetPenaltyStatus @default(PENDING)
  originalAmountBdt     Decimal                          @default(0) @db.Decimal(12, 2)
  appliedAmountBdt      Decimal?                         @db.Decimal(12, 2)
  waivedAmountBdt       Decimal?                         @db.Decimal(12, 2)
  penaltyLedgerEntryId  String?
  reversalLedgerEntryId String?
  appliedById           String?
  waivedById            String?
  adminNote             String?                          @db.Text
  appliedAt             DateTime?
  waivedAt              DateTime?
  createdAt             DateTime                         @default(now())
  updatedAt             DateTime                         @updatedAt

  @@index([businessId, status, createdAt])
  @@index([targetId])
  @@index([employeeId, createdAt])
  @@index([penaltyLedgerEntryId])
  @@index([reversalLedgerEntryId])
}

model TradingVolumeTargetAudit {
  id           String                   @id @default(cuid())
  targetId     String
  target       TradingDailyVolumeTarget @relation(fields: [targetId], references: [id], onDelete: Cascade)
  businessId   String
  action       String
  actorUserId  String?
  detail       String?                  @db.Text
  metadataJson String?                  @db.Text
  createdAt    DateTime                 @default(now())

  @@index([businessId, action, createdAt])
  @@index([targetId, createdAt])
  @@index([actorUserId, createdAt])
}

model TradingVolumeTargetSettings {
  businessId         String   @id
  autoPenaltyEnabled Boolean  @default(false)
  defaultPenaltyBdt  Decimal  @default(500) @db.Decimal(12, 2)
  updatedById        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

enum BusinessArchiveBatchStatus {
  PREVIEW
  COMPLETED
  RESTORED
  PARTIAL
}

model BusinessArchiveBatch {
  id                 String                     @id @default(cuid())
  name               String
  businessId         String
  moduleKeys         String
  status             BusinessArchiveBatchStatus @default(PREVIEW)
  recordCount        Int                        @default(0)
  dryRunSnapshot     String?                    @db.Text
  confirmationPhrase String?
  createdById        String
  createdAt          DateTime                   @default(now())
  completedAt        DateTime?
  restoredAt         DateTime?
  entities           BusinessArchiveEntity[]

  @@index([businessId, createdAt])
  @@index([status, createdAt])
}

model BusinessArchiveEntity {
  id           String               @id @default(cuid())
  batchId      String
  batch        BusinessArchiveBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  businessId   String
  moduleKey    String
  entityType   String
  entityId     String
  isArchived   Boolean              @default(true)
  archivedAt   DateTime             @default(now())
  archivedById String
  restoredAt   DateTime?
  restoredById String?

  @@unique([businessId, moduleKey, entityId])
  @@index([batchId])
  @@index([businessId, moduleKey, isArchived])
}

model BusinessArchiveAuditLog {
  id          String   @id @default(cuid())
  batchId     String?
  businessId  String
  action      String
  actorUserId String
  detailJson  String?  @db.Text
  createdAt   DateTime @default(now())

  @@index([businessId, createdAt])
  @@index([batchId, createdAt])
}

/// Hermes agent API audit trail — every write via /api/agent/* logs here.
/// Columns: actionType, resourceId, payload (jsonb), actor, ipAddress, createdAt
model AgentAuditLog {
  id         String   @id @default(cuid())
  actionType String
  resourceId String?
  payload    Json?
  actor      String   @default("agent_via_sir")
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([actionType, createdAt])
  @@index([createdAt])
  @@index([resourceId])
}

/// Agent-readable settings cache with version bump on PATCH.
model AgentSettings {
  id                   String   @id @default("global")
  settingsVersion      Int      @default(1)
  businessHours        Json?
  holidays             Json?
  lateThresholdMinutes Int      @default(15)
  finePolicy           Json?
  updatedAt            DateTime @updatedAt
  createdAt            DateTime @default(now())
}

// ─── AGENT MODULE (Phase 0+) ────────────────────────────────────────────────
// These tables are owned exclusively by the agent module (src/agent/).
// ERP code must never import from src/agent/ or query these tables directly.

/// Top-level workspace for grouping agent conversations (e.g. ALMA Lifestyle, Trading, Personal).
model AgentProject {
  id                 String              @id @default(uuid())
  name               String
  description        String?
  systemInstructions String?             @db.Text
  /// Business scope of this project. null = personal / cross-business.
  /// One of: 'ALMA_LIFESTYLE' | 'ALMA_TRADING' | null
  businessId         String?             @map("business_id")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  conversations      AgentConversation[]

  @@index([businessId])
  @@map("agent_projects")
}

/// A single conversation thread, optionally scoped to a project.
model AgentConversation {
  id             String          @id @default(uuid())
  projectId      String?
  project        AgentProject?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  title          String?
  model          String?
  source         String          @default("web")
  archived       Boolean         @default(false)
  summarizedAt   DateTime?       @map("summarized_at")
  lastMessageAt  DateTime?       @map("last_message_at")
  totalCostUsd   Float           @default(0) @map("total_cost_usd")
  contextSummary String?         @map("context_summary")
  compactedToId  String?         @map("compacted_to_id")
  /// Business scope inherited from project. null = personal / cross-business.
  /// One of: 'ALMA_LIFESTYLE' | 'ALMA_TRADING' | null
  businessId     String?         @map("business_id")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  messages       AgentMessage[]
  artifacts      AgentArtifact[]

  @@index([projectId])
  @@index([source])
  @@index([businessId])
  @@index([updatedAt(sort: Desc)])
  @@map("agent_conversations")
}

/// Individual turn in a conversation. content stores full Anthropic content blocks.
model AgentMessage {
  id             String            @id @default(uuid())
  conversationId String
  conversation   AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        Json
  tokensIn       Int?
  tokensOut      Int?
  costUsd        Decimal?          @db.Decimal(10, 6)
  usage          Json?
  createdAt      DateTime          @default(now())
  artifacts      AgentArtifact[]
  toolCalls      AgentToolCall[]

  @@index([conversationId, createdAt])
  @@map("agent_messages")
}

/// Rich output produced by the agent (code, markdown, HTML, images).
model AgentArtifact {
  id             String            @id @default(uuid())
  conversationId String
  conversation   AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  messageId      String?
  message        AgentMessage?     @relation(fields: [messageId], references: [id], onDelete: SetNull)
  type           String?
  title          String?
  content        String?           @db.Text
  version        Int               @default(1)
  createdAt      DateTime          @default(now())

  @@index([conversationId])
  @@index([messageId])
  @@map("agent_artifacts")
}

/// Owner's memory store. pgvector embedding column added in Phase 3.
model AgentMemory {
  id          String                       @id @default(uuid())
  scope       String
  key         String?
  content     String                       @db.Text
  pinned      Boolean                      @default(false)
  metadata    Json?
  embedding   Unsupported("vector(1536)")?
  importance  Int                          @default(2)
  accessCount Int                          @default(0) @map("access_count")
  lastUsedAt  DateTime?                    @map("last_used_at")
  createdAt   DateTime                     @default(now())
  updatedAt   DateTime                     @updatedAt

  @@index([scope])
  @@map("agent_memory")
}

/// Execution record for every tool the agent invokes.
model AgentToolCall {
  id         String        @id @default(uuid())
  messageId  String?
  message    AgentMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  toolName   String
  input      Json?
  output     Json?
  status     String?
  durationMs Int?
  error      String?
  createdAt  DateTime      @default(now())

  @@index([messageId])
  @@map("agent_tool_calls")
}

/// Costly/destructive actions pending owner confirmation before execution.
model AgentPendingAction {
  id             String    @id @default(uuid())
  conversationId String?
  type           String
  payload        Json
  summary        String    @db.Text
  costEstimate   Float?
  status         String    @default("pending")
  /// Business scope for routing/filtering ('ALMA_LIFESTYLE' | 'ALMA_TRADING').
  businessId     String    @default("ALMA_LIFESTYLE") @map("business_id")
  createdAt      DateTime  @default(now())
  resolvedAt     DateTime?
  result         Json?

  @@index([status])
  @@index([conversationId])
  @@index([businessId, status])
  @@map("agent_pending_actions")
}

model FamilyContact {
  id        String   @id @default(uuid())
  ownerId   String?  @map("owner_id")
  name      String
  relation  String
  phone     String
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@map("family_contacts")
}

model AgentNotification {
  id        String   @id @default(uuid())
  tier      Int
  category  String?
  title     String   @db.Text
  message   String   @db.Text
  channels  Json
  statuses  Json
  createdAt DateTime @default(now())

  @@index([tier])
  @@index([createdAt])
  @@map("agent_notifications")
}

// ─── PHASE 9: Personal Reminders ──────────────────────────────────────────────

model AgentReminder {
  id                   String    @id @default(uuid())
  title                String
  body                 String?   @db.Text
  dueAt                DateTime  @map("due_at")
  recurrenceRrule      String?   @map("recurrence_rrule")
  tier                 Int       @default(1)
  voice                Boolean   @default(true)
  status               String    @default("pending")
  snoozedUntil         DateTime? @map("snoozed_until")
  lastSentAt           DateTime? @map("last_sent_at")
  sendCount            Int       @default(0) @map("send_count")
  sourceConversationId String?   @map("source_conversation_id")
  createdAt            DateTime  @default(now()) @map("created_at")

  @@index([status, dueAt])
  @@index([dueAt])
  @@map("agent_reminders")
}

model AgentOwnerTodo {
  id                   String    @id @default(uuid())
  title                String
  detail               String?   @db.Text
  status               String    @default("open")
  priority             String    @default("normal")
  dueHint              String?   @map("due_hint")
  nudgeAfterDays       Int       @default(3) @map("nudge_after_days")
  lastNudgedAt         DateTime? @map("last_nudged_at")
  sourceConversationId String?   @map("source_conversation_id")
  createdAt            DateTime  @default(now()) @map("created_at")
  completedAt          DateTime? @map("completed_at")

  @@index([status, createdAt])
  @@map("agent_owner_todos")
}

model ProductContentAsset {
  id           String    @id @default(uuid())
  productCode  String    @map("product_code")
  name         String?
  category     String?
  fabric       String?   @db.Text
  imagePath    String    @map("image_path")
  familyMatch  Boolean   @default(false) @map("family_match")
  lastPostedAt DateTime? @map("last_posted_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([lastPostedAt])
  @@index([productCode])
  @@map("product_content_asset")
}

model BrandAsset {
  id        String   @id @default(uuid())
  kind      String   @unique
  path      String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("brand_asset")
}

model AgentBrandModel {
  id        String   @id
  name      String
  imagePath String   @map("image_path")
  role      String?  @unique
  isDefault Boolean  @default(false) @map("is_default")
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isDefault])
  @@map("agent_brand_models")
}

model AgentStaff {
  id             String                @id @default(uuid())
  name           String
  role           String
  telegramChatId String?
  ntfyTopic      String?               @map("ntfy_topic")
  active         Boolean               @default(true)
  /// Business scope this staff belongs to ('ALMA_LIFESTYLE' | 'ALMA_TRADING').
  businessId     String                @default("ALMA_LIFESTYLE") @map("business_id")
  /// Optional link to ERP User (Trading staff are linked to User accounts for account assignment).
  userId         String?               @map("user_id")
  user           User?                 @relation("AgentStaffUser", fields: [userId], references: [id], onDelete: SetNull)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  tasks          AgentStaffTask[]
  replyStats     AgentStaffReplyStat[]
  locations      AgentStaffLocation[]
  feedback       StaffFeedback[]

  @@index([businessId, active])
  @@index([userId])
  @@map("agent_staff")
}

model StaffLunch {
  id          String    @id @default(uuid())
  staffId     String    @map("staff_id")
  staffName   String?   @map("staff_name")
  lunchDate   String    @map("lunch_date")
  startedAt   DateTime  @map("started_at")
  endedAt     DateTime? @map("ended_at")
  durationMin Int?      @map("duration_min")
  overage     Boolean   @default(false)
  warned45    Boolean   @default(false) @map("warned_45")
  alerted60   Boolean   @default(false) @map("alerted_60")
  /// Business scope ('ALMA_LIFESTYLE' | 'ALMA_TRADING').
  businessId  String    @default("ALMA_LIFESTYLE") @map("business_id")

  @@index([staffId, lunchDate])
  @@index([businessId, lunchDate])
  @@map("staff_lunch")
}

model StaffLeave {
  id         String   @id @default(uuid())
  staffId    String   @map("staff_id")
  staffName  String?  @map("staff_name")
  businessId String?  @map("business_id")
  startDate  String   @map("start_date")
  endDate    String   @map("end_date")
  type       String   @default("leave")
  reason     String?  @db.Text
  status     String   @default("approved")
  createdAt  DateTime @default(now()) @map("created_at")
  approvedBy String?  @map("approved_by")

  @@index([staffId, startDate])
  @@map("staff_leave")
}

// ─── PHASE 6: Staff Tasks ───────────────────────────────────────────────────

model AgentStaffTask {
  id                 String                         @id @default(uuid())
  staffId            String                         @map("staff_id")
  staff              AgentStaff                     @relation(fields: [staffId], references: [id], onDelete: Cascade)
  title              String
  detail             String?                        @db.Text
  type               String                         @default("misc")
  productRef         String?                        @map("product_ref")
  status             String                         @default("proposed")
  proposedFor        DateTime                       @map("proposed_for") @db.Date
  completedAt        DateTime?                      @map("completed_at")
  carriedFromTaskId  String?                        @map("carried_from_task_id")
  carriedFrom        AgentStaffTask?                @relation("CarryForward", fields: [carriedFromTaskId], references: [id], onDelete: SetNull)
  carriedTasks       AgentStaffTask[]               @relation("CarryForward")
  source             String                         @default("agent")
  verificationStatus String                         @default("not_required") @map("verification_status")
  proofType          String?                        @map("proof_type")
  proofData          Json?                          @map("proof_data")
  reviewerNote       String?                        @map("reviewer_note") @db.Text
  redoCount          Int                            @default(0) @map("redo_count")
  /// Business scope inherited from staff ('ALMA_LIFESTYLE' | 'ALMA_TRADING').
  businessId         String                         @default("ALMA_LIFESTYLE") @map("business_id")
  createdAt          DateTime                       @default(now()) @map("created_at")
  marketingHistory   AgentProductMarketingHistory[]

  @@index([staffId])
  @@index([proposedFor, status])
  @@index([status])
  @@index([businessId, proposedFor, status])
  @@map("staff_tasks")
}

model AgentProductMarketingHistory {
  id             String          @id @default(uuid())
  productRef     String          @map("product_ref")
  business       String
  lastPromotedAt DateTime        @default(now()) @map("last_promoted_at")
  contentType    String?         @map("content_type")
  taskId         String?         @map("task_id")
  task           AgentStaffTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  notes          String?         @db.Text
  createdAt      DateTime        @default(now()) @map("created_at")

  @@index([productRef, lastPromotedAt(sort: Desc)])
  @@index([business, lastPromotedAt(sort: Desc)])
  @@map("product_marketing_history")
}

// ─── PHASE 6: Salah ─────────────────────────────────────────────────────────

model AgentSalahRecord {
  id            String    @id @default(uuid())
  date          DateTime  @db.Date
  waqt          String
  windowStart   DateTime  @map("window_start")
  windowEnd     DateTime  @map("window_end")
  status        String    @default("pending")
  confirmedAt   DateTime? @map("confirmed_at")
  remindersSent Int       @default(0) @map("reminders_sent")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@unique([date, waqt])
  @@index([date(sort: Desc)])
  @@index([status])
  @@map("salah_records")
}

model AgentSalahOverride {
  id           String    @id @default(uuid())
  date         DateTime? @db.Date
  waqt         String?
  overrideTime DateTime? @map("override_time")
  delayUntil   DateTime? @map("delay_until")
  skip         Boolean   @default(false)
