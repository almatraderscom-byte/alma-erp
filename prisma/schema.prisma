// ─── PHASE 7: Watchdog heartbeats ────────────────────────────────────────────

model AgentHeartbeat {
  service    String   @id
  lastBeatAt DateTime @default(now()) @map("last_beat_at")

  @@map("agent_heartbeats")
}

model AgentDutyLog {
  id        String    @id @default(uuid())
  duty      String
  label     String
  dutyDate  String    @map("duty_date")
  status    String    @default("pending")
  detail    String?   @db.Text
  ranAt     DateTime? @map("ran_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@unique([duty, dutyDate])
  @@index([dutyDate])
  @@map("agent_duty_log")
}

model AgentOutcome {
  id            String    @id @default(uuid())
  type          String
  subjectKind   String    @map("subject_kind")
  subjectId     String?   @map("subject_id")
  subjectName   String?   @map("subject_name")
  suggestion    String    @db.Text
  rationale     String?   @db.Text
  metric        String
  baselineValue Float?    @map("baseline_value")
  predicted     String?
  measureAfter  String    @map("measure_after")
  status        String    @default("pending")
  actualValue   Float?    @map("actual_value")
  result        String?
  learning      String?   @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")
  measuredAt    DateTime? @map("measured_at")
